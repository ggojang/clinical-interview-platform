{
  "id": "policy.uscdi-interoperability-overlay",
  "version": "0.1.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "purpose": "Use USCDI and USCDI+ as versioned interoperability and gap-analysis overlays without allowing them to determine clinical interview content.",
  "authority_boundary": {
    "clinical_question_authority": false,
    "clinical_safety_rule_authority": false,
    "completion_rule_authority": false,
    "interoperability_coverage_authority": true,
    "may_create_unreviewed_gap_candidates": true,
    "may_make_patient_question_required": false
  },
  "jurisdiction": {
    "framework_jurisdiction": "US",
    "deployment_jurisdiction": "KR",
    "apply_us_regulatory_requirements": false,
    "primary_terminology_and_claim_bindings": [
      "SNOMED_CT_International_via_STOM",
      "LOINC",
      "KCD-8/9",
      "HIRA_EDI"
    ],
    "us_specific_vocabularies_are_crosswalks_only": true
  },
  "mapping_statuses": ["exact", "partial", "broader", "narrower", "contextual", "unmapped", "not_patient_collectable"],
  "collection_roles": ["patient_collectable", "patient_or_record", "record_or_provider", "output_generated"],
  "patient_question_policy": {
    "ask_only_when_supported_by_encounter_context_or_clinical_intent": true,
    "do_not_ask_only_to_raise_uscdi_coverage": true,
    "preserve_data_absent_reason": true,
    "preserve_information_source": true,
    "do_not_convert_unknown_to_negative": true
  },
  "version_policy": {
    "core_baseline": "USCDI-v6",
    "draft_versions_are_nonbinding_candidates": true,
    "uscdi_plus_domain_maturity_must_be_preserved": true,
    "source_manifest": "source-manifest.uscdi-interoperability-research"
  },
  "provenance": {
    "created_by": {"type": "ai", "id": "codex-gpt5"},
    "created_at": "2026-07-16T00:00:00Z",
    "source_refs": [
      "source.uscdi.v6.2025",
      "source.uscdi-plus.overview.2026",
      "docs/context/024-interoperability-and-fhir.md"
    ],
    "review_status": "unreviewed",
    "version": "0.1.0"
  }
}
