{
  "id": "policy.korean-claim-code-binding",
  "version": "0.2.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "purpose": "Verify or map a claim code or claim-catalog name explicitly supplied by the user or extracted from user-provided material, without replacing clinical semantics.",
  "activation": {
    "allowed_triggers": [
      "user_provided_exact_claim_code",
      "user_provided_claim_catalog_name",
      "user_requested_claim_code_verification",
      "uploaded_document_contains_explicit_claim_code_or_name",
      "user_provided_medication_product_name"
    ],
    "forbidden_triggers": [
      "routine_clinical_fact_collection",
      "symptom_or_reason_for_encounter_alone",
      "ai_generated_differential_diagnosis",
      "ai_generated_test_or_treatment_suggestion",
      "automatic_enrichment_of_every_clinical_fact"
    ],
    "proactive_claim_lookup": false,
    "do_not_ask_for_claim_code_during_routine_questionnaire": true,
    "lookup_only_when_supplied_input_or_explicit_user_goal_exists": true
  },
  "input_handling": {
    "exact_code": "verify_in_the_matching_domain_without_name_search_when_domain_is_known",
    "catalog_name": "search_the_matching_domain_and_keep_candidates_until_verified",
    "medication_product_name": "search_hira_medication_not_ingredient_only_semantic_mapping",
    "uploaded_scan_or_document": [
      "extract_code_or_catalog_name_locally",
      "preserve_document_source_page_or_region_and_ocr_uncertainty",
      "send_only_the_minimal_extracted_code_or_short_name_to_stom",
      "never_send_the_file_image_or_surrounding_patient_narrative_to_stom"
    ],
    "uncertain_ocr_code": "request_confirmation_or_keep_unresolved_before_lookup_selection"
  },
  "domains": {
    "diagnosis": {
      "classification_systems": [
        {"name": "KCD-8", "system": "http://www.hl7korea.or.kr/CodeSystem/kostat-kcd-8"},
        {"name": "KCD-9", "system": "http://www.hl7korea.or.kr/CodeSystem/kostat-kcd-9"}
      ],
      "kcd8_search_operation": "GET /search/KCD8?q={normalized_diagnosis_term}",
      "kcd9_verification_operation": "FHIR CodeSystem $lookup with the KCD-9 system URI",
      "kcd9_general_search_currently_exposed": false,
      "kcd9_morphology_search_is_not_general_diagnosis_search": true,
      "never_assume_kcd8_code_is_unchanged_in_kcd9": true,
      "retain_snomed_ct_clinical_semantics_separately": true
    },
    "procedure": {
      "name": "HIRA EDI Procedure",
      "system": "http://www.hl7korea.or.kr/CodeSystem/hira-edi-procedure",
      "search_operation": "GET /hira/행위/search?q={normalized_term}",
      "detail_operation": "GET /hira/행위/{code}",
      "fact_id": "claim.procedure.code"
    },
    "medication": {
      "name": "HIRA EDI Medication",
      "system": "http://www.hl7korea.or.kr/CodeSystem/hira-edi-medication",
      "search_operation": "GET /hira/약제/search?q={normalized_drug_term}",
      "detail_operation": "GET /hira/약제/{code}",
      "fact_id": "claim.medication.code"
    },
    "material": {
      "name": "HIRA EDI Material",
      "system": "http://www.hl7korea.or.kr/CodeSystem/hira-edi-material",
      "search_operation": "GET /hira/치료재료/search?q={normalized_material_term}",
      "detail_operation": "GET /hira/치료재료/{code}",
      "fact_id": "claim.material.code",
      "group_result_is_not_final_item_code": true
    }
  },
  "workflow": [
    "confirm_allowed_activation_trigger",
    "preserve_user_or_document_supplied_value_and_source",
    "identify_domain_before_lookup",
    "normalize_short_deidentified_term",
    "search_only_the_matching_code_system",
    "retain_multiple_candidates_when_context_is_insufficient",
    "verify_selected_code_with_detail_or_fhir_lookup",
    "record_system_version_effective_date_and_lookup_time",
    "preserve_source_clinical_fact_and_mapping_provenance"
  ],
  "selection_rules": {
    "never_send_raw_patient_narrative_or_direct_identifier": true,
    "never_auto_select_from_name_similarity_alone_when_multiple_billable_candidates_exist": true,
    "procedure_requires_sufficient_method_site_and_context": true,
    "medication_requires_sufficient_ingredient_strength_dose_form_and_product_context": true,
    "material_requires_final_item_not_group_result": true,
    "unknown_or_ambiguous_mapping_remains_unresolved": true
  },
  "clinical_boundary": {
    "claim_code_does_not_establish_diagnosis": true,
    "do_not_bind_possible_differential_as_final_claim_diagnosis": true,
    "diagnosis_mapping_candidate_requires_explicit_diagnosis_context": true,
    "claim_code_never_controls_interview_priority_safety_or_differential": true,
    "reimbursement_price_or_coverage_is_not_clinical_fact": true,
    "terminology_service_failure_does_not_block_interview": true
  },
  "fhir_r4_projection": {
    "diagnosis": ["Condition.code.coding"],
    "procedure": ["Procedure.code.coding", "ServiceRequest.code.coding"],
    "medication": ["Medication.code.coding", "MedicationRequest.medicationCodeableConcept.coding"],
    "material": ["Device.type.coding", "SupplyDelivery.suppliedItem.itemCodeableConcept.coding"],
    "retain_multiple_codings_with_system_and_version": true,
    "do_not_emit_unverified_candidate_as_user_selected_or_final": true
  },
  "refresh": {
    "profile": "terminology_server",
    "interval_days": 30,
    "recheck_on_code_inactivation_or_claim_catalog_change": true
  },
  "provenance": {
    "created_by": {"type": "ai", "id": "codex-gpt5"},
    "created_at": "2026-07-14T00:00:00Z",
    "source_refs": [
      "source.stom.fhir-r4-terminology-server",
      "https://stom.infoclinic.co/v2/api-docs"
    ],
    "review_status": "unreviewed",
    "version": "0.2.0"
  }
}
