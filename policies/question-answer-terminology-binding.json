{
  "id": "policy.question-answer-terminology-binding",
  "version": "0.5.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "purpose": "Bind every interview question and coded answer without overstating semantic equivalence.",
  "question_binding": {
    "preferred_system_order": [
      "http://loinc.org",
      "http://snomed.info/sct",
      "https://ggojang.github.io/clinical-interview-platform/fhir/CodeSystem/clinical-interview-question"
    ],
    "loinc_use": "preferred_for_a_verified_observable_or_assessment_question",
    "snomed_use": "secondary_for_a_verified_observable_entity_or_related_clinical_semantic",
    "local_fallback_required": true,
    "local_code_is_internal_question_id": true,
    "fhir_item_code_rule": "emit_the_local_code_and_only_verified_exact_or_equivalent_standard_mappings",
    "non_equivalent_mapping_rule": "retain_in_mapping_metadata_but_do_not_emit_as_an_equivalent_Questionnaire.item.code"
  },
  "question_atomicity": {
    "definition": "one_question_collects_one_answer-bearing_clinical_data_element",
    "required_before_standard_mapping": true,
    "exact_or_equivalent_mapping_requires_verified_atomic_fact": true,
    "composite_question_action": "split_into_atomic_questions_before_attempting_LOINC_or_SNOMED_equivalence",
    "composite_question_fallback": "retain_local_question_code_and_add_to_refactoring_queue",
    "quality_review": "run_repository_wide_atomicity_and_mapping_simulation_on_every_terminology_change_and_periodically_with_autonomous_simulation",
    "examples": {
      "atomic": "current_pain_NRS_score",
      "composite": "language_interpreter_hearing_vision_literacy_and_digital_support"
    }
  },
  "mapping_scope": {
    "dynamic_ai_generated_interview_questions": "included",
    "reusable_clinician_submission_questions": "included",
    "source_defined_fixed_questionnaires": "excluded_by_default",
    "fixed_questionnaire_exception": "map_only_after_an_explicit_instruction_and_verification_against_the_official_instrument_or_standard_artifact",
    "do_not_rewrite_fixed_question_text_for_mapping": true
  },
  "answer_binding": {
    "precedence_rule": "when an exact or equivalent target FHIR R4 element mapping exists, apply that element's official ValueSet binding before the generic SNOMED CT preference",
    "preferred_system_order": [
      "target_FHIR_R4_element_ValueSet_when_applicable",
      "http://snomed.info/sct",
      "https://ggojang.github.io/clinical-interview-platform/fhir/CodeSystem/clinical-interview-answer"
    ],
    "coded_clinical_answers": "use_verified_SNOMED_CT_when_the_answer_concept_is_represented",
    "local_fallback_required": true,
    "primitive_answers": {
      "boolean": "QuestionnaireResponse.answer.valueBoolean_only_when_the_receiving_profile_explicitly_requires_a_primitive_boolean;_clinical_yes_no_defaults_to_a_coded_choice",
      "integer": "QuestionnaireResponse.answer.valueInteger",
      "quantity": "QuestionnaireResponse.answer.valueQuantity_with_UCUM_when_a_unit_is_known",
      "date": "QuestionnaireResponse.answer.valueDate",
      "dateTime": "QuestionnaireResponse.answer.valueDateTime",
      "string": "QuestionnaireResponse.answer.valueString",
      "rule": "do_not_invent_a_SNOMED_or_local_answer_code_for_a_literal_measurement_date_or_narrative"
    },
    "source_defined_instrument_answers": "retain_the_official_answer_code_system_and_answer_list;_add_SNOMED_only_when_a_verified_equivalent_exists",
    "data_absent_rule": "unknown_declined_not_asked_and_not_applicable_states_are_not_negative_answers_and_use_FHIR_DataAbsentReason_when_semantically_applicable",
    "answer_value_set_required_for_coded_choice": true,
    "answer_value_set_selection": {
      "all_answers_verified_SNOMED_CT": "a-sct-{semantic-name}",
      "some_answers_verified_SNOMED_CT": "a-mixed-{fact-name}",
      "no_standard_answer_mapping": "a-local-{fact-name}",
      "official_LOINC_answer_list": "a-loinc-{LL-code-or-semantic-name}",
      "local_companion_for_every_dynamic_coded_fact": "a-local-{fact-name}",
      "application_extension_of_reference": "a-extended-{semantic-name}"
    }
  },
  "answer_value_set_naming": {
    "canonical_base": "https://ggojang.github.io/clinical-interview-platform/fhir/ValueSet/",
    "id_pattern": "a-{scope}-{semantic-name}",
    "scopes": {
      "sct": "only_SNOMED_CT_codes",
      "loinc": "official_LOINC_LA_answer_codes_or_external_answer_list",
      "local": "only_clinical_interview_local_answer_codes",
      "mixed": "SNOMED_CT_where_verified_and_local_codes_for_the_remaining_answers",
      "extended": "separate_application_ValueSet_importing_an_unchanged_reference_and_adding_verified_codes"
    },
    "fhir_id_max_length": 64,
    "long_id_rule": "truncate_the_slug_and_append_a_stable_SHA256_suffix",
    "version_rule": "terminology_and_content_versions_are_resource_metadata_not_part_of_the_id",
    "examples": [
      "a-sct-yes-no",
      "a-local-yes-no",
      "a-sct-mild-moderate-severe",
      "a-mixed-symptom-course",
      "a-extended-context-specific-symptom-course"
    ]
  },
  "fhir_valueset_service": {
    "policy_id": "policy.fhir-valueset-service",
    "primary_build_time_base_url": "http://localhost:8088/fhir",
    "remote_fallback_base_url": "https://stom.infoclinic.co/fhir",
    "external_standard_valueset_rule": "resolve_by_canonical_and_optional_version_then_expand_and_validate_code",
    "project_valueset_rule": "generate_and_validate_locally_until_an_explicit_authorized_publication_step",
    "runtime_lookup_required": false,
    "reference_reconciliation": "canonical_and_version_then_normalized_membership_content",
    "reference_preservation": "reuse_if_present_or_publish_unchanged_if_absent",
    "extension_rule": "create_a_separate_a-extended_ValueSet_that_imports_the_reference",
    "dynamic_projection": "open-choice_when_out_of_reference_standard_answers_are_clinically_permitted",
    "closed_projection": "choice_for_required_closed_or_source_defined_items"
  },
  "mapping_relations": [
    "exact",
    "equivalent",
    "broader",
    "narrower",
    "partial",
    "related",
    "unmapped"
  ],
  "mapping_requirements": [
    "internal_object_identifier",
    "system",
    "code",
    "display",
    "mapping_relation",
    "terminology_version",
    "verification_source",
    "verified_at",
    "review_status",
    "confidence"
  ],
  "safety_boundaries": {
    "label_similarity_cannot_establish_equivalence": true,
    "composite_question_cannot_inherit_an_atomic_code_as_exact": true,
    "terminology_mapping_does_not_control_question_priority_or_safety": true,
    "runtime_terminology_lookup_required": false,
    "unmapped_does_not_block_research_test_collection": true,
    "never_convert_unknown_or_declined_to_false": true,
    "fixed_questionnaire_is_not_automatically_mapped": true,
    "partial_answer_mapping_requires_a_complete_mixed_or_local_ValueSet": true
  },
  "fhir_r4_projection": {
    "question": "Questionnaire.item.code",
    "coded_answer_option": "Questionnaire.item.answerOption.valueCoding_or_answerValueSet",
    "coded_response": "QuestionnaireResponse.item.answer.valueCoding",
    "literal_response": "QuestionnaireResponse.item.answer.value_x",
    "question_response_link": "Questionnaire.item.linkId_equals_QuestionnaireResponse.item.linkId",
    "preserve_local_code_alongside_standard_code": true,
    "resource_element_binding_policy": "policy.fhir-r4-element-terminology-binding",
    "element_binding_rule": "required_extensible_preferred_and_example_bindings_are_applied_according_to_strength_when_the_internal_Fact_has_an_exact_or_equivalent_target_element_mapping"
  },
  "reference_search_priority": [
    "official_LOINC_panel_Questionnaire_and_Answer_List_ValueSet",
    "HL7_FHIR_core_profiles_examples_and_implementation_guides",
    "HL7_US_Core_profiles_examples_and_required_ValueSets",
    "NLM_VSAC_published_ValueSets_when_access_and_license_allow",
    "SNOMED_International_implementation_guides_reference_sets_and_ECL",
    "STOM_verified_terminology_content",
    "new_local_code_only_after_the_above_sources_are_checked"
  ],
  "terminology_versions": {
    "LOINC": "2.82",
    "SNOMED_CT_International": "http://snomed.info/sct/900000000000207008/version/20260701"
  },
  "refresh": {
    "profile": "terminology_server",
    "interval_days": 30,
    "last_verified_at": "2026-07-23",
    "next_verification_at": "2026-08-22",
    "policy_id": "policy.knowledge-refresh"
  },
  "provenance": {
    "created_by": {
      "type": "ai",
      "id": "codex-gpt5"
    },
    "created_at": "2026-07-23T00:00:00Z",
    "source_refs": [
      "https://hl7.org/fhir/R4/questionnaire.html",
      "https://loinc.org/fhir/",
      "https://loinc.org/answer-file/",
      "https://hl7.org/fhir/R4/valueset.html",
      "https://hl7.org/fhir/us/core/STU6.1/StructureDefinition-us-core-questionnaireresponse.html",
      "https://ecqi.healthit.gov/tool/value-set-authority-center-vsac",
      "https://docs.snomed.org/snomed-ct-practical-guides/snomed-ct-starter-guide/6-snomed-ct-concept-model",
      "https://docs.snomed.org/implementation-guides/implementation-fact-sheets/snomed-ct-clinical-decision-support-systems-and-cql",
      "source.stom.fhir-r4-terminology-server",
      "policy.fhir-valueset-service",
      "docs/context/024-interoperability-and-fhir.md"
    ],
    "review_status": "unreviewed",
    "version": "0.1.0"
  }
}
