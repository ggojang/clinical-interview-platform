{
  "id": "policy.question-answer-terminology-binding",
  "version": "0.1.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "purpose": "Bind every interview question and coded answer without overstating semantic equivalence.",
  "question_binding": {
    "preferred_system_order": [
      "http://loinc.org",
      "http://snomed.info/sct",
      "https://ggojang.github.io/clinical-interview-platform/fhir/CodeSystem/clinical-interview-question"
    ],
    "loinc_use": "preferred_for_a_verified_observable_or_assessment_question",
    "snomed_use": "secondary_for_a_verified_observable_entity_or_related_clinical_semantic",
    "local_fallback_required": true,
    "local_code_is_internal_question_id": true,
    "fhir_item_code_rule": "emit_the_local_code_and_only_verified_exact_or_equivalent_standard_mappings",
    "non_equivalent_mapping_rule": "retain_in_mapping_metadata_but_do_not_emit_as_an_equivalent_Questionnaire.item.code"
  },
  "answer_binding": {
    "preferred_system_order": [
      "http://snomed.info/sct",
      "https://ggojang.github.io/clinical-interview-platform/fhir/CodeSystem/clinical-interview-answer"
    ],
    "coded_clinical_answers": "use_verified_SNOMED_CT_when_the_answer_concept_is_represented",
    "local_fallback_required": true,
    "primitive_answers": {
      "boolean": "QuestionnaireResponse.answer.valueBoolean",
      "integer": "QuestionnaireResponse.answer.valueInteger",
      "quantity": "QuestionnaireResponse.answer.valueQuantity_with_UCUM_when_a_unit_is_known",
      "date": "QuestionnaireResponse.answer.valueDate",
      "dateTime": "QuestionnaireResponse.answer.valueDateTime",
      "string": "QuestionnaireResponse.answer.valueString",
      "rule": "do_not_invent_a_SNOMED_or_local_answer_code_for_a_literal_measurement_date_or_narrative"
    },
    "source_defined_instrument_answers": "retain_the_official_answer_code_system_and_answer_list;_add_SNOMED_only_when_a_verified_equivalent_exists",
    "data_absent_rule": "unknown_declined_not_asked_and_not_applicable_states_are_not_negative_answers_and_use_FHIR_DataAbsentReason_when_semantically_applicable"
  },
  "mapping_relations": [
    "exact",
    "equivalent",
    "broader",
    "narrower",
    "partial",
    "related",
    "unmapped"
  ],
  "mapping_requirements": [
    "internal_object_identifier",
    "system",
    "code",
    "display",
    "mapping_relation",
    "terminology_version",
    "verification_source",
    "verified_at",
    "review_status",
    "confidence"
  ],
  "safety_boundaries": {
    "label_similarity_cannot_establish_equivalence": true,
    "composite_question_cannot_inherit_an_atomic_code_as_exact": true,
    "terminology_mapping_does_not_control_question_priority_or_safety": true,
    "runtime_terminology_lookup_required": false,
    "unmapped_does_not_block_research_test_collection": true,
    "never_convert_unknown_or_declined_to_false": true
  },
  "fhir_r4_projection": {
    "question": "Questionnaire.item.code",
    "coded_answer_option": "Questionnaire.item.answerOption.valueCoding_or_answerValueSet",
    "coded_response": "QuestionnaireResponse.item.answer.valueCoding",
    "literal_response": "QuestionnaireResponse.item.answer.value_x",
    "question_response_link": "Questionnaire.item.linkId_equals_QuestionnaireResponse.item.linkId",
    "preserve_local_code_alongside_standard_code": true
  },
  "terminology_versions": {
    "LOINC": "2.82",
    "SNOMED_CT_International": "http://snomed.info/sct/900000000000207008/version/20260701"
  },
  "refresh": {
    "profile": "terminology_server",
    "interval_days": 30,
    "last_verified_at": "2026-07-23",
    "next_verification_at": "2026-08-22",
    "policy_id": "policy.knowledge-refresh"
  },
  "provenance": {
    "created_by": {
      "type": "ai",
      "id": "codex-gpt5"
    },
    "created_at": "2026-07-23T00:00:00Z",
    "source_refs": [
      "https://hl7.org/fhir/R4/questionnaire.html",
      "https://loinc.org/fhir/",
      "https://loinc.org/answer-file/",
      "https://docs.snomed.org/snomed-ct-practical-guides/snomed-ct-starter-guide/6-snomed-ct-concept-model",
      "source.stom.fhir-r4-terminology-server",
      "docs/context/024-interoperability-and-fhir.md"
    ],
    "review_status": "unreviewed",
    "version": "0.1.0"
  }
}
