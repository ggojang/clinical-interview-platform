{
  "id": "policy.encounter-context-review",
  "version": "0.8.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "encounter_context": {
    "establish_after_reason_for_encounter_before_first_clinical_item": true,
    "diagnosis_independent": true,
    "fields": [
      "care_setting",
      "encounter_type",
      "interview_initiator",
      "interview_mode",
      "available_information",
      "time_constraint",
      "clinical_responsibility"
    ],
    "do_not_repeat_context_already_explicit_in_user_input": true,
    "emergency_or_urgent_context": {
      "safety_first": true,
      "do_not_skip_reason_for_encounter": true,
      "short_question_budget": true
    },
    "remote_mode": {
      "applies_to": ["telephone", "video", "chat", "asynchronous_questionnaire"],
      "physical_examination_available": false,
      "do_not_convert_unavailable_examination_into_negative_finding": true
    },
    "caregiver_initiated": {
      "response_source": "proxy_report",
      "source_attribution_required": true,
      "do_not_represent_proxy_report_as_patient_report": true
    },
    "follow_up_or_specialist_context": [
      "treatment_response",
      "medication_adherence",
      "disease_progression"
    ],
    "health_checkup_or_screening_context": [
      "prevention",
      "screening",
      "risk_assessment"
    ]
  },
  "result_follow_up": {
    "clarification_question_ko": "오늘은 의료기관에서 검사결과를 확인하려는 것인가요, 아니면 검사결과의 판독이나 설명을 원하시나요?",
    "options": [
      {"code": "institution_result_check", "display_ko": "의료기관에서 결과 확인"},
      {"code": "interpretation_request", "display_ko": "검사결과 판독·설명 요청"},
      {"code": "both", "display_ko": "둘 다"}
    ],
    "institution_result_check": {
      "request_upload": false,
      "check": ["result.abnormal_notice", "result.new_concern"],
      "when_no_abnormality_or_concern": "ask_additional_request_then_complete"
    },
    "interpretation_request": {
      "request_upload_once": true,
      "accepted_input": ["image", "pdf", "text"],
      "never_repeat_upload_request": true
    }
  },
  "uploaded_clinical_material": {
    "accepted_input": ["image", "pdf", "text", "document"],
    "supported_content": ["laboratory_result", "imaging_report", "pathology_report", "prescription", "medication_list", "medical_history", "screening_form"],
    "extract_only_explicit_information": true,
    "fact_source": "uploaded_document",
    "preserve_document_date_and_uncertainty": true,
    "do_not_treat_inferred_illegible_or_missing_content_as_negative": true,
    "do_not_overwrite_patient_report": true,
    "conflict_handling": "preserve_both_sources_and_ask_targeted_clarification",
    "reuse_explicit_current_facts_to_avoid_duplicate_questions": true,
    "ask_only_for_missing_ambiguous_conflicting_or_safety_relevant_facts": true,
    "unreadable_material": "request_clearer_crop_or_text_once",
    "raw_medical_image_boundary": "do_not_claim_definitive_radiologic_or_pathologic_diagnosis",
    "do_not_send_patient_material_to_actions": true,
    "do_not_publish_patient_material": true,
    "conversation_only_in_test_version": true
  },
  "completion_handoff": {
    "requires_explicit_user_confirmation": true,
    "pre_confirmation_steps": [
      "offer_final_free_text_concern",
      "resolve_required_safety_follow_up",
      "summarize_missing_uncertain_and_conflicting_information"
    ],
    "confirmation_question_ko": "설문을 어떻게 마칠까요?",
    "options": [
      {"number": 1, "code": "complete", "display_ko": "설문 종료 및 결과 확정"},
      {"number": 2, "code": "continue_or_edit", "display_ko": "답변 추가·수정"},
      {"number": 3, "code": "stop", "display_ko": "설문 중단"},
      {"number": 4, "code": "unknown", "display_ko": "잘 모르겠음"},
      {"number": 5, "code": "decline", "display_ko": "답변하지 않음"}
    ],
    "do_not_mark_completed_before_confirmation": true,
    "completion_announcement_ko": "설문이 종료되었습니다. 현재 응답은 이 종료 시점을 기준으로 확정되었습니다. 이후 입력은 기존 결과의 수정 요청 또는 새로운 상담 사유로 구분됩니다.",
    "record_on_transition": [
      "interview_status",
      "completion_reason",
      "completion_confirmed_at",
      "last_modified_at",
      "unanswered_fact_ids",
      "dataAbsentReason",
      "consent_state"
    ],
    "completion_confirmation_is_not_consent": true,
    "clinician_previsit_content": {
      "include_reason_for_encounter_specific_facts": true,
      "include_collected_and_currently_required_facts": true,
      "include_question_label_and_clinical_group": true,
      "include_value_status_confidence_and_data_absent_reason": true,
      "identify_safety_relevant_facts": true,
      "identify_missing_required_and_must_be_known_facts": true,
      "preserve_conflicting_facts": true,
      "do_not_limit_handoff_to_common_history_sections": true
    },
    "future_fhir_r4_questionnaire_response_status": {
      "collecting": "in-progress",
      "awaiting_user_confirmation": "in-progress",
      "paused_or_undecided": "in-progress",
      "user_completed": "completed",
      "user_stopped": "stopped",
      "corrected_after_completion": "amended",
      "administratively_invalidated": "entered-in-error"
    },
    "post_completion_input": "classify_as_amendment_or_new_reason_for_encounter_before_collecting"
  },
  "answer_revision": {
    "available_states": [
      "in_progress",
      "awaiting_user_confirmation",
      "completed"
    ],
    "entry_commands": ["수정", "답변 수정", "edit answer"],
    "menu_instruction_ko": "수정할 질문은 '수정 Q2'처럼 입력해 주세요. 질문 없이 제공한 정보는 U번호를 사용합니다.",
    "edit_reference_format": "Q{positive_integer}",
    "unprompted_fact_reference_format": "U{positive_integer}",
    "legacy_edit_reference_accepted_but_not_displayed": "E{positive_integer}",
    "never_use_bare_question_option_number_as_edit_reference": true,
    "menu_item_fields": [
      "edit_reference",
      "question_or_item_label",
      "current_value_or_response_state",
      "fact_id"
    ],
    "workflow": [
      "preserve_current_unanswered_question",
      "show_only_answers_available_for_revision",
      "select_one_item_by_edit_reference",
      "show_current_answer_and_request_replacement",
      "record_replacement_as_explicit_correction",
      "recompute_safety_rules",
      "recompute_conditional_question_branch",
      "recompute_missing_conflicting_and_data_absent_facts",
      "recompute_completion_eligibility",
      "confirm_changed_item_and_resume_or_reopen_questionnaire"
    ],
    "value_entry": {
      "reuse_original_question_choices_when_available": true,
      "binary_numeric_codes": {
        "1": "yes",
        "2": "no",
        "3": "asked-unknown",
        "4": "asked-declined"
      },
      "free_text_allowed_when_original_fact_accepts_free_text": true,
      "do_not_apply_replacement_to_any_other_fact": true
    },
    "audit": {
      "never_delete_or_silently_overwrite_prior_answer": true,
      "preserve_prior_value_response_state_evidence_and_timestamp": true,
      "record_correction_actor_time_reason_and_source": true,
      "data_absent_reason_may_be_replaced_but_remains_in_history": true,
      "future_fhir_provenance_ready": true
    },
    "conditional_branch_change": {
      "new_branch_facts_become_required_when_applicable": true,
      "prior_branch_answers_are_preserved_in_history": true,
      "prior_branch_answers_do_not_satisfy_new_branch": true,
      "do_not_delete_answers_from_inactive_branch": true
    },
    "after_completion": {
      "classify_as_amendment_not_new_encounter_when_same_reason_for_encounter": true,
      "questionnaire_response_status": "amended",
      "invalidate_prior_final_summary": true,
      "require_completion_reconfirmation_after_recalculation": true
    },
    "safety": {
      "reassessment_precedes_routine_resume": true,
      "new_urgent_or_emergency_result_interrupts_revision_flow": true,
      "explain_why_escalation_is_recommended": true
    },
    "completion_hint_ko": "답변을 바꾸려면 언제든지 '수정'이라고 입력하세요.",
    "provenance_marker": "출처: [공동 작업 지식] 답변 수정 정책 · [AI 표현] 안내 문장"
  },
  "answer_understanding_clarification": {
    "trigger_conditions": [
      "possible_typographical_error",
      "invalid_or_out_of_range_option_number",
      "ambiguous_meaning",
      "answer_cannot_be_reliably_mapped_to_current_fact"
    ],
    "decision_order": [
      "extract_and_apply_any_explicit_safety_relevant_information",
      "reassess_safety",
      "determine_whether_response_answers_current_question",
      "route_clearly_unrelated_content_to_off_path_recovery",
      "request_targeted_clarification_when_current_answer_remains_uncertain"
    ],
    "preserve_current_question_as_unanswered": true,
    "do_not_advance_to_next_question": true,
    "do_not_infer_negative_unknown_or_refusal_from_parse_failure": true,
    "do_not_store_suggested_interpretation_as_fact_before_confirmation": true,
    "likely_typo_flow": {
      "may_offer_one_concise_normalized_interpretation": true,
      "confirmation_question_ko": "입력하신 내용을 '{suggested_interpretation}'으로 이해하면 될까요?",
      "confirmation_options": [
        {"number": 1, "code": "confirm", "display_ko": "예, 맞습니다"},
        {"number": 2, "code": "reject_and_reenter", "display_ko": "아니오, 다시 입력"},
        {"number": 3, "code": "unknown", "display_ko": "잘 모르겠음"},
        {"number": 5, "code": "decline", "display_ko": "답변하지 않음"}
      ],
      "auto_accept_threshold": "never"
    },
    "ambiguous_flow": {
      "ask_one_specific_clarifying_question_at_a_time": true,
      "repeat_original_question_with_original_choices_when_no_safe_interpretation": true,
      "message_ko": "응답을 명확히 이해하지 못했습니다. 아래 질문에 다시 답해 주세요.",
      "allow_korean_or_english_free_text_when_fact_supports_free_text": true
    },
    "retry_policy": {
      "clarification_does_not_count_as_a_new_unique_clinical_question": true,
      "after_repeated_failure_offer_unknown_decline_or_free_text": true,
      "never_force_data_absent_reason_without_explicit_user_choice": true
    },
    "safety": {
      "urgent_or_emergency_routing_precedes_clarification": true,
      "preserve_unanswered_question_when_safety_interrupts": true
    },
    "audit_fields": [
      "question_id",
      "fact_id",
      "raw_response_in_conversation_only",
      "clarification_reason",
      "suggested_interpretation",
      "confirmation_result",
      "attempt_count"
    ],
    "provenance_marker": "출처: [공동 작업 지식] 응답 재확인 정책 · [AI 표현] 재질문"
  },
  "test_access_limit_notice": {
    "show_once_per_conversation": true,
    "timing": "after_reason_for_encounter_before_first_question",
    "must_not_replace_reason_for_encounter_entry": true,
    "message_ko": "테스트 안내: ChatGPT 무료 플랜에서는 GPT 사용량 또는 파일·이미지 업로드 한도로 설문이 중간에 일시 중단될 수 있습니다. 한도에 도달하면 ChatGPT에 표시되는 초기화 시점을 확인한 뒤 다시 진행해 주세요. 종료 확인 전에 중단된 설문은 완료된 결과로 처리되지 않습니다.",
    "do_not_claim_fixed_quota_or_reset_time": true,
    "rate_limit_interruption_status": "in-progress",
    "repeat_only_when_user_asks_or_limit_recovery_is_relevant": true,
    "source_url": "https://help.openai.com/en/articles/9275245-chatgpt-free-tier-faq"
  },
  "response_provenance_display": {
    "show_legend_once_per_conversation": true,
    "timing": "after_reason_for_encounter_before_first_question",
    "compact_marker_required_for_every_question": true,
    "source_classes": {
      "project_knowledge": {
        "display_ko": "공동 작업 지식",
        "meaning": "compiled Knowledge, Fact, Question, Rule, policy, or source summary from this repository"
      },
      "ai_expression": {
        "display_ko": "AI 표현",
        "meaning": "language adaptation or concise rewording without changing project semantics"
      },
      "ai_generated": {
        "display_ko": "AI 자체 생성",
        "meaning": "clarification, interpretation, explanation, or candidate not present in compiled project knowledge"
      },
      "stom_terminology": {
        "display_ko": "STOM 용어 조회",
        "meaning": "live provisional terminology candidate or code verification"
      },
      "user_report": {
        "display_ko": "사용자 제공",
        "meaning": "information directly reported by the user"
      },
      "uploaded_document": {
        "display_ko": "첨부자료",
        "meaning": "information explicitly extracted from an uploaded file or scan"
      }
    },
    "question_marker_examples": {
      "compiled_question_reworded": "출처: [공동 작업 지식] 질문 목적·선택 · [AI 표현] 문장",
      "ai_only_clarification": "출처: [AI 자체 생성] 프로젝트 지식에 없는 보완 질문",
      "terminology_result": "용어: [STOM 용어 조회] 후보·코드 검증",
      "document_follow_up": "근거 정보: [첨부자료] · 질문 생성: [AI 자체 생성]"
    },
    "never_label_ai_generated_content_as_project_knowledge": true,
    "never_hide_mixed_origin": true,
    "require_project_object_or_source_id_for_project_label": true,
    "record_fields": [
      "origin_class",
      "project_object_ids",
      "external_source_ids",
      "terminology_source_and_version",
      "ai_contribution",
      "uncertainty"
    ],
    "final_report_section_ko": "출처 및 생성 구분",
    "future_fhir_provenance_ready": true
  },
  "off_path_recovery": {
    "preserve_current_question_as_unanswered": true,
    "store_detour_as_additional_comment": true,
    "safety_reassessment_precedes_detour_response": true,
    "related_non_answer": "resolve_briefly_then_repeat_current_question_once",
    "topic_detour": "resolve_or_report_then_offer_recovery_menu",
    "new_reason_for_encounter": "offer_to_close_current_interview_before_starting_new_encounter",
    "explicit_finish_or_stop_request": "skip_reprompt_and_enter_completion_or_stop_flow",
    "recovery_question_ko": "현재 설문에서 벗어난 다른 주제로 전환되었습니다. 설문을 어떻게 진행할까요?",
    "options": [
      {"number": 1, "code": "return_to_questionnaire", "display_ko": "현재 설문 질문으로 돌아가기"},
      {"number": 2, "code": "begin_completion", "display_ko": "지금까지 내용으로 설문 종료 절차 진행"},
      {"number": 3, "code": "stop_interview", "display_ko": "현재 설문 중단"},
      {"number": 4, "code": "unknown", "display_ko": "잘 모르겠음"},
      {"number": 5, "code": "decline", "display_ko": "답변하지 않음"}
    ],
    "route": {
      "return_to_questionnaire": "repeat_same_unanswered_question_without_losing_detour_result",
      "begin_completion": "summarize_missing_facts_then_use_completion_handoff",
      "stop_interview": "set_user_stopped",
      "unknown": "keep_in_progress_and_explain_choices_once",
      "decline": "keep_in_progress_without_forcing_current_answer"
    },
    "data_absent_on_completion_after_detour": {
      "current_question_explicitly_left_unanswered": "asked-declined",
      "remaining_never_asked_facts": "not-asked"
    },
    "do_not_repeat_unrelated_question_answer": true,
    "numeric_reply_scope": "immediately_preceding_recovery_question",
    "provenance_marker": "출처: [공동 작업 지식] 경로 복구 정책 · [AI 표현] 안내 문장",
    "record_fields": [
      "detour_type",
      "additional_comment_resolution",
      "recovery_choice",
      "unanswered_question_id",
      "resume_or_completion_transition"
    ]
  },
  "question_choice_semantic_alignment": {
    "pre_send_validation_required": true,
    "exactly_one_presentation_pattern": true,
    "binary_single_proposition": {
      "use_when": "one_clinical_proposition_is_being_asked",
      "stem_rule": "ask_one_complete_yes_or_no_proposition",
      "forbidden_stem_phrases": ["다음 중", "해당되는 항목", "모두 골라"],
      "domain_options": [
        {"number": 1, "code": "yes", "display_ko": "예"},
        {"number": 2, "code": "no", "display_ko": "아니오"}
      ],
      "metadata_options": [
        {"number": 3, "code": "unknown", "display_ko": "잘 모르겠음"},
        {"number": 5, "code": "decline", "display_ko": "답변하지 않음"}
      ],
      "display_group_label_ko": "응답",
      "options_answer_the_whole_proposition": true,
      "example_stem_ko": "지금 갑자기 시작된 참기 어려울 정도의 심한 복통이 있나요?"
    },
    "multiple_clinical_choices": {
      "use_when": "two_or_more_distinct_clinical_findings_are_being_offered",
      "stem_must_state": ["multiple_choice", "select_all_that_apply"],
      "every_clinical_finding_must_be_a_displayed_domain_option": true,
      "do_not_use_yes_or_no_as_domain_options": true,
      "append_order": ["none_of_the_above", "unknown", "decline"],
      "display_group_labels_ko": {
        "domain_options": "해당 증상 — 복수 선택 가능",
        "response_state_options": "그 외 응답"
      },
      "exclusive_options": ["none_of_the_above", "unknown", "decline"],
      "numbering": "continuous_after_all_clinical_domain_options",
      "numeric_reply_accepts": "one_or_more_option_numbers",
      "do_not_put_unoffered_clinical_findings_in_trailing_warning_text": true
    },
    "safety_gate": {
      "same_alignment_rules_apply": true,
      "prefer_single_binary_question_when_only_one_rule_is_activated": true,
      "use_checklist_only_for_findings_supported_by_loaded_compiled_rules": true,
      "map_each_selected_finding_to_its_own_fact_or_rule": true,
      "none_unknown_and_decline_never_mean_a_clinical_finding": true
    },
    "invalid_combinations": [
      "plural_or_select_from_stem_with_only_one_clinical_domain_option",
      "checklist_stem_with_yes_or_no_options",
      "binary_stem_with_multiple_unlabeled_clinical_findings",
      "warning_paragraph_that_introduces_additional_unoffered_answer_candidates"
    ],
    "on_validation_failure": "rewrite_stem_and_complete_option_set_before_sending",
    "provenance_marker": "출처: [공동 작업 지식] 질문-보기 정합성 정책 · [AI 표현] 문장"
  },
  "adaptive_interview_turn_contract": {
    "reason_for_encounter_enters_interview_not_general_medical_consultation": true,
    "knowledge_package_must_be_loaded_before_first_clinical_question": true,
    "collecting_phase": {
      "exactly_one_question_per_assistant_turn": true,
      "one_question_may_contain_one_stem_and_its_answer_options": true,
      "capture_all_explicit_facts_from_multi_fact_user_answer": true,
      "ask_only_one_next_missing_fact": true,
      "forbid_batched_question_stems": true,
      "forbid_ranked_differential_or_most_likely_disease": true,
      "forbid_management_exercise_self_test_imaging_or_treatment_advice": true,
      "allow_only_brief_safety_action_and_rationale_when_time_sensitive": true
    },
    "question_identity": {
      "display_format": "Q{positive_integer}",
      "assign_on_first_display": true,
      "monotonic_within_encounter": true,
      "never_reset_after_answer": true,
      "repeat_or_clarification_reuses_same_reference": true,
      "answer_option_numbers_restart_within_each_question": true,
      "bare_number_always_means_current_question_option": true,
      "edit_command_uses_question_reference": "수정 Q{positive_integer}"
    },
    "completion_phase": {
      "requires_explicit_completion_confirmation": true,
      "final_guidance_only_after_confirmation": true,
      "final_sections": [
        "clinician_previsit_summary",
        "safety_status_and_rationale",
        "possible_differential_considerations_not_diagnosis",
        "clinician_examination_or_test_topics",
        "general_management_and_medication_information"
      ],
      "never_claim_diagnosis_or_certainty": true
    }
  },
  "longitudinal_context_review": {
    "review_all_on_first_encounter": true,
