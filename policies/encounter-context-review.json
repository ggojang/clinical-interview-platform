      },
      "ai_generated": {
        "display_ko": "AI 자체 생성",
        "meaning": "clarification, interpretation, explanation, or candidate not present in compiled project knowledge"
      },
      "stom_terminology": {
        "display_ko": "STOM 용어 조회",
        "meaning": "live provisional terminology candidate or code verification"
      },
      "user_report": {
        "display_ko": "사용자 제공",
        "meaning": "information directly reported by the user"
      },
      "uploaded_document": {
        "display_ko": "첨부자료",
        "meaning": "information explicitly extracted from an uploaded file or scan"
      }
    },
    "question_marker_examples": {
      "compiled_question_reworded": "출처: [공동 작업 지식] 질문 목적·선택 · [AI 표현] 문장",
      "ai_only_clarification": "출처: [AI 자체 생성] 프로젝트 지식에 없는 보완 질문",
      "terminology_result": "용어: [STOM 용어 조회] 후보·코드 검증",
      "document_follow_up": "근거 정보: [첨부자료] · 질문 생성: [AI 자체 생성]"
    },
    "never_label_ai_generated_content_as_project_knowledge": true,
    "never_hide_mixed_origin": true,
    "require_project_object_or_source_id_for_project_label": true,
    "record_fields": [
      "origin_class",
      "project_object_ids",
      "external_source_ids",
      "terminology_source_and_version",
      "ai_contribution",
      "uncertainty"
    ],
    "final_report_section_ko": "출처 및 생성 구분",
    "future_fhir_provenance_ready": true
  },
  "off_path_recovery": {
    "preserve_current_question_as_unanswered": true,
    "store_detour_as_additional_comment": true,
    "safety_reassessment_precedes_detour_response": true,
    "related_non_answer": "resolve_briefly_then_repeat_current_question_once",
    "topic_detour": "resolve_or_report_then_offer_recovery_menu",
    "new_reason_for_encounter": "offer_to_close_current_interview_before_starting_new_encounter",
    "explicit_finish_or_stop_request": "skip_reprompt_and_enter_completion_or_stop_flow",
    "recovery_question_ko": "현재 설문에서 벗어난 다른 주제로 전환되었습니다. 설문을 어떻게 진행할까요?",
    "options": [
      {"number": 1, "code": "return_to_questionnaire", "display_ko": "현재 설문 질문으로 돌아가기"},
      {"number": 2, "code": "begin_completion", "display_ko": "지금까지 내용으로 설문 종료 절차 진행"},
      {"number": 3, "code": "stop_interview", "display_ko": "현재 설문 중단"},
      {"number": 4, "code": "unknown", "display_ko": "잘 모르겠음"},
      {"number": 5, "code": "decline", "display_ko": "답변하지 않음"}
    ],
    "route": {
      "return_to_questionnaire": "repeat_same_unanswered_question_without_losing_detour_result",
