{
  "id": "policy.encounter-context-review",
  "version": "0.1.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "result_follow_up": {
    "clarification_question_ko": "오늘은 의료기관에서 검사결과를 확인하려는 것인가요, 아니면 검사결과의 판독이나 설명을 원하시나요?",
    "options": [
      {"code": "institution_result_check", "display_ko": "의료기관에서 결과 확인"},
      {"code": "interpretation_request", "display_ko": "검사결과 판독·설명 요청"},
      {"code": "both", "display_ko": "둘 다"}
    ],
    "institution_result_check": {
      "request_upload": false,
      "check": ["result.abnormal_notice", "result.new_concern"],
      "when_no_abnormality_or_concern": "ask_additional_request_then_complete"
    },
    "interpretation_request": {
      "request_upload_once": true,
      "accepted_input": ["image", "pdf", "text"],
      "never_repeat_upload_request": true
    }
  },
  "uploaded_clinical_material": {
    "accepted_input": ["image", "pdf", "text", "document"],
    "supported_content": ["laboratory_result", "imaging_report", "pathology_report", "prescription", "medication_list", "medical_history", "screening_form"],
    "extract_only_explicit_information": true,
    "fact_source": "uploaded_document",
    "preserve_document_date_and_uncertainty": true,
    "do_not_treat_inferred_illegible_or_missing_content_as_negative": true,
    "do_not_overwrite_patient_report": true,
    "conflict_handling": "preserve_both_sources_and_ask_targeted_clarification",
    "reuse_explicit_current_facts_to_avoid_duplicate_questions": true,
    "ask_only_for_missing_ambiguous_conflicting_or_safety_relevant_facts": true,
    "unreadable_material": "request_clearer_crop_or_text_once",
    "raw_medical_image_boundary": "do_not_claim_definitive_radiologic_or_pathologic_diagnosis",
    "do_not_send_patient_material_to_actions": true,
    "do_not_publish_patient_material": true,
    "conversation_only_in_test_version": true
  },
  "longitudinal_context_review": {
    "review_all_on_first_encounter": true,
    "unknown_last_confirmed_at": "ask_single_recency_gate_then_due_if_still_unknown",
    "recency_gate_question_ko": "처음 작성하시는 건가요? 아니라면 과거력·복용약·가족력·음주·흡연 정보를 마지막으로 확인하거나 수정한 시기를 알려주세요.",
    "do_not_ask_separate_recency_question_per_group": true,
    "groups": {
      "history.conditions": {"interval_days": 365},
      "medication.current": {"interval_days": 90},
      "history.family": {"interval_days": 365},
      "social.alcohol": {"interval_days": 365},
      "social.smoking": {"interval_days": 365}
    },
    "review_only_due_groups": true,
    "allow_user_reported_change_to_trigger_review": true
  },
  "provenance": {
    "created_by": {"type": "ai", "id": "codex-gpt5"},
    "created_at": "2026-07-14T00:00:00Z",
    "source_refs": ["docs/context/002-encounter-context.md", "docs/context/017-clinical-memory.md"],
    "review_status": "unreviewed",
    "version": "0.1.0"
  }
}
