{
  "id": "policy.encounter-context-review",
  "version": "0.1.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "result_follow_up": {
    "clarification_question_ko": "오늘은 의료기관에서 검사결과를 확인하려는 것인가요, 아니면 검사결과의 판독이나 설명을 원하시나요?",
    "options": [
      {"code": "institution_result_check", "display_ko": "의료기관에서 결과 확인"},
      {"code": "interpretation_request", "display_ko": "검사결과 판독·설명 요청"},
      {"code": "both", "display_ko": "둘 다"}
    ],
    "institution_result_check": {
      "request_upload": false,
      "check": ["result.abnormal_notice", "result.new_concern"],
      "when_no_abnormality_or_concern": "ask_additional_request_then_complete"
    },
    "interpretation_request": {
      "request_upload_once": true,
      "accepted_input": ["image", "pdf", "text"],
      "never_repeat_upload_request": true
    }
  },
  "uploaded_clinical_material": {
    "accepted_input": ["image", "pdf", "text", "document"],
    "supported_content": ["laboratory_result", "imaging_report", "pathology_report", "prescription", "medication_list", "medical_history", "screening_form"],
    "extract_only_explicit_information": true,
    "fact_source": "uploaded_document",
    "preserve_document_date_and_uncertainty": true,
    "do_not_treat_inferred_illegible_or_missing_content_as_negative": true,
    "do_not_overwrite_patient_report": true,
    "conflict_handling": "preserve_both_sources_and_ask_targeted_clarification",
    "reuse_explicit_current_facts_to_avoid_duplicate_questions": true,
    "ask_only_for_missing_ambiguous_conflicting_or_safety_relevant_facts": true,
    "unreadable_material": "request_clearer_crop_or_text_once",
    "raw_medical_image_boundary": "do_not_claim_definitive_radiologic_or_pathologic_diagnosis",
    "do_not_send_patient_material_to_actions": true,
    "do_not_publish_patient_material": true,
    "conversation_only_in_test_version": true
  },
  "completion_handoff": {
    "requires_explicit_user_confirmation": true,
    "pre_confirmation_steps": [
      "offer_final_free_text_concern",
      "resolve_required_safety_follow_up",
      "summarize_missing_uncertain_and_conflicting_information"
    ],
    "confirmation_question_ko": "설문을 어떻게 마칠까요?",
    "options": [
      {"number": 1, "code": "complete", "display_ko": "설문 종료 및 결과 확정"},
      {"number": 2, "code": "continue_or_edit", "display_ko": "답변 추가·수정"},
      {"number": 3, "code": "stop", "display_ko": "설문 중단"},
      {"number": 4, "code": "unknown", "display_ko": "잘 모르겠음"},
      {"number": 5, "code": "decline", "display_ko": "답변하지 않음"}
    ],
    "do_not_mark_completed_before_confirmation": true,
    "completion_announcement_ko": "설문이 종료되었습니다. 현재 응답은 이 종료 시점을 기준으로 확정되었습니다. 이후 입력은 기존 결과의 수정 요청 또는 새로운 상담 사유로 구분됩니다.",
    "record_on_transition": [
      "interview_status",
      "completion_reason",
      "completion_confirmed_at",
      "last_modified_at",
      "unanswered_fact_ids",
      "dataAbsentReason",
      "consent_state"
    ],
    "completion_confirmation_is_not_consent": true,
    "future_fhir_r4_questionnaire_response_status": {
      "collecting": "in-progress",
      "awaiting_user_confirmation": "in-progress",
      "paused_or_undecided": "in-progress",
      "user_completed": "completed",
      "user_stopped": "stopped",
      "corrected_after_completion": "amended",
      "administratively_invalidated": "entered-in-error"
    },
    "post_completion_input": "classify_as_amendment_or_new_reason_for_encounter_before_collecting"
  },
  "test_access_limit_notice": {
    "show_once_per_conversation": true,
    "timing": "after_reason_for_encounter_before_first_question",
    "must_not_replace_reason_for_encounter_entry": true,
    "message_ko": "테스트 안내: ChatGPT 무료 플랜에서는 GPT 사용량 또는 파일·이미지 업로드 한도로 설문이 중간에 일시 중단될 수 있습니다. 한도에 도달하면 ChatGPT에 표시되는 초기화 시점을 확인한 뒤 다시 진행해 주세요. 종료 확인 전에 중단된 설문은 완료된 결과로 처리되지 않습니다.",
    "do_not_claim_fixed_quota_or_reset_time": true,
    "rate_limit_interruption_status": "in-progress",
    "repeat_only_when_user_asks_or_limit_recovery_is_relevant": true,
    "source_url": "https://help.openai.com/en/articles/9275245-chatgpt-free-tier-faq"
  },
  "response_provenance_display": {
    "show_legend_once_per_conversation": true,
    "timing": "after_reason_for_encounter_before_first_question",
    "compact_marker_required_for_every_question": true,
    "source_classes": {
      "project_knowledge": {
        "display_ko": "공동 작업 지식",
        "meaning": "compiled Knowledge, Fact, Question, Rule, policy, or source summary from this repository"
      },
      "ai_expression": {
        "display_ko": "AI 표현",
        "meaning": "language adaptation or concise rewording without changing project semantics"
      },
      "ai_generated": {
        "display_ko": "AI 자체 생성",
        "meaning": "clarification, interpretation, explanation, or candidate not present in compiled project knowledge"
      },
      "stom_terminology": {
        "display_ko": "STOM 용어 조회",
        "meaning": "live provisional terminology candidate or code verification"
      },
      "user_report": {
        "display_ko": "사용자 제공",
        "meaning": "information directly reported by the user"
      },
      "uploaded_document": {
        "display_ko": "첨부자료",
        "meaning": "information explicitly extracted from an uploaded file or scan"
      }
    },
    "question_marker_examples": {
      "compiled_question_reworded": "출처: [공동 작업 지식] 질문 목적·선택 · [AI 표현] 문장",
      "ai_only_clarification": "출처: [AI 자체 생성] 프로젝트 지식에 없는 보완 질문",
      "terminology_result": "용어: [STOM 용어 조회] 후보·코드 검증",
      "document_follow_up": "근거 정보: [첨부자료] · 질문 생성: [AI 자체 생성]"
    },
    "never_label_ai_generated_content_as_project_knowledge": true,
    "never_hide_mixed_origin": true,
    "require_project_object_or_source_id_for_project_label": true,
    "record_fields": [
      "origin_class",
      "project_object_ids",
      "external_source_ids",
      "terminology_source_and_version",
      "ai_contribution",
      "uncertainty"
    ],
    "final_report_section_ko": "출처 및 생성 구분",
    "future_fhir_provenance_ready": true
  },
  "longitudinal_context_review": {
    "review_all_on_first_encounter": true,
    "unknown_last_confirmed_at": "ask_single_recency_gate_then_due_if_still_unknown",
    "recency_gate_question_ko": "처음 작성하시는 건가요? 아니라면 과거력·복용약·가족력·음주·흡연 정보를 마지막으로 확인하거나 수정한 시기를 알려주세요.",
    "do_not_ask_separate_recency_question_per_group": true,
    "groups": {
      "history.conditions": {"interval_days": 365},
      "medication.current": {"interval_days": 90},
      "history.family": {"interval_days": 365},
      "social.alcohol": {"interval_days": 365},
      "social.smoking": {"interval_days": 365}
    },
    "review_only_due_groups": true,
    "allow_user_reported_change_to_trigger_review": true
  },
  "provenance": {
    "created_by": {"type": "ai", "id": "codex-gpt5"},
    "created_at": "2026-07-14T00:00:00Z",
    "source_refs": ["docs/context/002-encounter-context.md", "docs/context/017-clinical-memory.md"],
    "review_status": "unreviewed",
    "version": "0.1.0"
  }
}
