{
  "id": "policy.fhir-valueset-service",
  "version": "0.3.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "purpose": "Use STOM FHIR R4 ValueSet services for Build-Time terminology discovery, expansion and validation without coupling Interview Runtime to a terminology server.",
  "endpoint_order": [
    {
      "id": "stom-local",
      "base_url": "http://localhost:8088/fhir",
      "priority": 1,
      "role": "primary_build_time",
      "availability": "local_environment"
    },
    {
      "id": "stom-remote",
      "base_url": "https://stom.infoclinic.co/fhir",
      "priority": 2,
      "role": "remote_build_time_fallback",
      "availability": "network_and_authorization_dependent"
    }
  ],
  "configuration": {
    "environment_variable": "CLINICAL_INTERVIEW_FHIR_TERMINOLOGY_BASE_URL",
    "default_base_url": "http://localhost:8088/fhir",
    "fhir_version": "4.0.1",
    "read_only_terminology_adapter": true,
    "allowed_terminology_http_methods": ["GET"],
    "authenticated_publication_method": "PUT",
    "authenticated_publication_header": "X-API-Key",
    "authenticated_publication_token_variable": "TERM_ADMIN_TOKEN",
    "timeout_seconds": 20
  },
  "value_set_workflow": {
    "loinc_official_answer_lists": {
      "scope": "all_official_LL_answer_lists_exposed_by_STOM",
      "aggregate_canonical": "http://loinc.org/vs/ll",
      "individual_canonical_pattern": "http://loinc.org/vs/{LL-code}",
      "registration": [
        "catalog_every_LL_identifier_canonical_display_and_observed_member_count",
        "preserve_the_official_LOINC_canonical",
        "resolve_each_individual_canonical_with_ValueSet_expand_at_build_time",
        "audit_aggregate_completeness_and_every_individual_expansion",
        "record_aggregate_ValueSet_and_LOINC_CodeSystem_versions_separately",
        "bind_only_an_applicable_verified_LL_canonical_in_Questionnaire.answerValueSet",
        "do_not_embed_unused_answer_lists_in_compiled_packages"
      ],
      "server_publication": "do_not_create_redundant_resources_when_STOM_already_resolves_the_official_canonical",
      "project_namespace": "a-loinc_is_reserved_for_project_owned_non_LL_LOINC_coded_sets",
      "version_mismatch_behavior": "retain_both_versions_and_emit_a_quality_warning",
      "runtime_dependency": false
    },
    "reference_first_reconciliation": [
      "identify_reference_canonical_version_and_membership_definition",
      "search_same_canonical_and_version",
      "compare_normalized_compose_or_expansion_membership",
      "reuse_an_exact_reference_when_present",
      "report_content_equivalent_resources_with_other_canonicals_as_duplicate_candidates_only",
      "never_substitute_a_different_canonical_based_only_on_membership_equivalence",
      "if_absent_publish_the_reference_resource_without_semantic_modification",
      "never_overwrite_a_canonical_version_with_different_membership"
    ],
    "external_standard_valueset": [
      "search_by_canonical_url_and_optional_version",
      "expand_with_canonical_url",
      "validate_candidate_code_with_canonical_url_system_code",
      "record_server_software_terminology_version_timestamp_and_result",
      "reference_the_verified_canonical_in_Questionnaire.answerValueSet"
    ],
    "project_generated_valueset": [
      "build_a-sct_a-loinc_a-local_or_a-mixed_resource_in_repository",
      "validate_complete_compose_and_local_code_coverage",
      "do_not_assume_the_server_knows_the_project_canonical",
      "publish_or_register_only_in_an_explicit_authenticated_deployment_step",
      "search_canonical_and_check_id_collision_before_create",
      "reuse_an_existing_identical_canonical_version_without_writing",
      "refuse_an_existing_canonical_version_with_different_membership",
      "never_update_an_existing_ValueSet_through_the_reconciliation_publisher",
      "verify_returned_canonical_after_write"
    ],
    "application_extension": [
      "never_add_codes_to_the_reference_ValueSet",
      "create_a_separate_a-extended-{semantic-name}_ValueSet",
      "import_the_reference_as_compose.include.valueSet_with_version_when_available",
      "add_only_needed_individually_verified_standard_codes",
      "require_verification_source_for_every_added_code",
      "allow_local_codes_only_by_explicit_exception",
      "record_the_reference_canonical_in_origin_extension_and_purpose",
      "use_open-choice_for_dynamic_extensible_question_projection",
      "retain_choice_for_closed_required_or_source_defined_items"
    ],
    "source_defined_fixed_questionnaire": "excluded_from_automatic_mapping_and_valueset_replacement_unless_explicitly_requested",
    "server_failure": "use_only_a_versioned_previously_verified_artifact_or_local_compiled_ValueSet_and_mark_live_verification_unavailable"
  },
  "required_capabilities": {
    "resource": "ValueSet",
    "interactions": ["read", "search-type"],
    "operations": ["$expand", "$validate-code"]
  },
  "observed_local_server": {
    "checked_at": "2026-07-23",
    "software_name": "STOM Terminology Server",
    "software_version": "1.0.0",
    "fhir_version": "4.0.1",
    "valueset_total_before_project_publication": 2568,
    "observed_interactions": ["create", "delete", "read", "search-type", "update"],
    "observed_operations": ["$compare", "$expand", "$validate-code"],
    "mutation_operations_authorized_for_this_platform": "explicit_authenticated_PUT_only",
    "probe_valueset": "http://terminology.hl7.org/ValueSet/yes-no-unknown-not-applicable",
    "probe_result": "search_expand_validate_code_passed",
    "project_publication": {
      "resource_count": 284,
      "created": 284,
      "post_write_canonical_verified": 284,
      "post_publication_dry_run_unchanged": 284,
      "representative_snomed_local_and_mixed_validation": "passed"
    },
    "loinc_answer_lists": {
      "aggregate_canonical": "http://loinc.org/vs/ll",
      "aggregate_valueset_version": "2.80",
      "loinc_codesystem_version": "2.82",
      "version_alignment": "metadata_mismatch",
      "answer_list_count": 4955,
      "individual_expansion_checked": 4955,
      "individual_expansion_failures": 0,
      "zero_member_lists": 0,
      "membership_total": 33944,
      "server_resources_created": 0
    }
  },
  "safety_boundaries": {
    "runtime_terminology_lookup_required": false,
    "terminology_result_does_not_select_questions": true,
    "terminology_result_does_not_set_urgency": true,
    "terminology_result_does_not_establish_diagnosis": true,
    "label_similarity_does_not_establish_equivalence": true,
    "no_automatic_POST_PUT_DELETE": true,
    "explicit_authenticated_PUT_for_publication": true,
    "no_patient_text_or_response_is_sent": true,
    "reference_valueset_is_never_mutated": true,
    "content_equivalence_does_not_erase_reference_provenance": true,
    "fixed_instrument_valuesets_are_closed_unless_explicitly_authorized": true
  },
  "provenance": {
    "created_by": {"type": "ai", "id": "codex-gpt5"},
    "created_at": "2026-07-23T00:00:00Z",
    "source_refs": [
      "http://localhost:8088/fhir/metadata",
