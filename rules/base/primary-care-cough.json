    {
      "id": "rule.safety.chest_pain_with_dyspnea",
      "type": "safety",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.chest_pain",
            "equals": true
          },
          {
            "fact": "symptom.dyspnea",
            "in": [
              "moderate",
              "severe"
            ]
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      },
      "version": "0.1.0",
      "status": "research_only",
      "provenance": {
        "created_by": {
          "type": "ai",
