        ],
        "review_status": "unreviewed",
        "version": "0.1.0"
      }
    },
    {
      "id": "rule.safety.hemoptysis",
      "type": "safety",
      "priority": 900,
      "when": {
        "fact": "symptom.hemoptysis",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      },
      "version": "0.1.0",
      "status": "research_only",
      "provenance": {
