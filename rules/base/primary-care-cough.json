{
  "id": "rules.primary-care-cough",
  "version": "0.1.0",
  "rules": [
    {
      "id": "rule.activate.cough",
      "type": "activation",
      "priority": 100,
      "when": {
        "rfe": "rfe.cough"
      },
      "then": {
        "activate_intents": [
          "intent.characterize_symptom",
          "intent.screen_red_flags",
          "intent.differentiate_common_causes"
        ]
      },
      "version": "0.1.0",
      "status": "research_only",
      "provenance": {
        "created_by": {
          "type": "ai",
          "id": "codex-gpt5"
        },
        "created_at": "2026-07-13T00:00:00Z",
        "source_refs": [
          "specifications/reasoning-loop.md",
          "specifications/common-cause-prioritization.md",
          "knowledge/semantic/red-flags/respiratory.yaml"
        ],
        "review_status": "unreviewed",
        "version": "0.1.0"
      }
    },
    {
      "id": "rule.safety.severe_breathing_difficulty",
      "type": "safety",
      "priority": 1000,
      "when": {
        "fact": "symptom.dyspnea",
        "equals": "severe"
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      },
      "version": "0.1.0",
      "status": "research_only",
      "provenance": {
        "created_by": {
          "type": "ai",
          "id": "codex-gpt5"
        },
        "created_at": "2026-07-13T00:00:00Z",
        "source_refs": [
