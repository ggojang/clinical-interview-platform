{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rule Graph",
  "type": "object",
  "required": [
    "id",
    "version",
    "rules",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "priority",
          "when",
          "then",
          "version",
          "status",
          "provenance"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "activation",
              "applicability",
              "requirement",
              "completion",
              "priority",
              "suppression",
              "conflict",
              "safety",
              "transition",
              "stop",
              "mapping"
            ]
          },
          "priority": {
            "type": "integer"
          },
          "when": {
            "type": "object"
          },
          "then": {
            "type": "object"
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "provenance": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
