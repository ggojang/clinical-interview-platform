{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulation Patient",
  "type": "object",
  "required": [
    "id",
    "persona",
    "initial_statement",
    "hidden_state",
    "expected",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "persona": {
      "type": "object"
    },
    "initial_statement": {
      "type": "object"
    },
    "hidden_state": {
      "type": "object"
    },
    "response_behavior": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "dataAbsentReason": {
            "enum": ["asked-unknown", "asked-declined", "not-applicable"]
          }
        },
        "additionalProperties": true
      }
    },
    "simulation_language": {
      "enum": ["en", "ko"]
    },
    "expected": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
