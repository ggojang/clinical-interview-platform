{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interview Pattern",
  "type": "object",
  "required": [
    "id",
    "version",
    "purpose",
    "activation",
    "required_facts",
    "safety_rules",
    "completion",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "activation": {
      "type": "object"
    },
    "required_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "optional_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safety_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completion": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
