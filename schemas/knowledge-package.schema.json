{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Package",
  "type": "object",
  "required": [
    "package_id",
    "package_version",
    "scope",
    "knowledge_graph",
    "rule_graph",
    "interview_completion_policy",
    "coverage",
    "compatibility",
    "provenance",
    "semantic_digest"
  ],
  "properties": {
    "package_id": {
      "type": "string"
    },
    "package_version": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "knowledge_graph": {
      "type": "object"
    },
    "rule_graph": {
      "type": "object"
    },
    "coverage": {
      "type": "object"
    },
    "interview_completion_policy": {
      "type": "object"
    },
    "compatibility": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    },
    "semantic_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
