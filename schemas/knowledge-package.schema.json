{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Package",
  "type": "object",
  "required": [
    "package_id",
    "package_version",
    "scope",
    "knowledge_graph",
    "rule_graph",
    "interview_completion_policy",
    "coverage",
    "interoperability_coverage",
    "compatibility",
    "provenance",
    "semantic_digest"
  ],
  "properties": {
    "package_id": {
      "type": "string"
    },
    "package_version": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "knowledge_graph": {
      "type": "object"
    },
    "rule_graph": {
      "type": "object"
    },
    "coverage": {
      "type": "object"
    },
    "interoperability_coverage": {
      "type": "object",
      "required": [
        "status",
        "review_status",
        "clinical_authority",
        "completion_authority",
        "jurisdiction",
        "core",
        "uscdi_plus_domains"
      ],
      "properties": {
        "status": {"const": "research_only"},
        "review_status": {"const": "unreviewed"},
        "clinical_authority": {"const": false},
        "completion_authority": {"const": false},
        "jurisdiction": {"type": "object"},
        "core": {"type": "object"},
        "uscdi_plus_domains": {"type": "array"}
      }
    },
    "interview_completion_policy": {
      "type": "object"
    },
    "compatibility": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    },
    "semantic_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
