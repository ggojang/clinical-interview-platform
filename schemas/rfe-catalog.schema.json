{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Primary Care Reason for Encounter Catalog",
  "type": "object",
  "required": ["id", "version", "status", "entries", "provenance"],
  "properties": {
    "id": {"type": "string"},
    "version": {"type": "string"},
    "status": {"enum": ["research_only", "reviewed"]},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "display", "priority_tier", "implementation_status"],
        "properties": {
          "id": {"type": "string", "pattern": "^rfe\\."},
          "display": {"type": "string"},
          "priority_tier": {"type": "integer", "minimum": 1},
          "implementation_status": {"enum": ["planned", "in_progress", "implemented"]},
          "package_id": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "provenance": {"type": "object"}
  },
  "additionalProperties": true
}
