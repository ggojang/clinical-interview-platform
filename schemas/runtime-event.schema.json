{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runtime Event",
  "type": "object",
  "required": [
    "event_id",
    "session_id",
    "sequence",
    "type",
    "actor",
    "created_at",
    "package_id",
    "package_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "type": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "package_id": {
      "type": "string"
    },
    "package_version": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
