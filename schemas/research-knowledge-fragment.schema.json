{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Knowledge Fragment",
  "type": "object",
  "required": [
    "id",
    "version",
    "status",
    "usage_modes",
    "source_manifest",
    "entries",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "const": "research_only"
    },
    "usage_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "research_test",
          "simulation"
        ]
      }
    },
    "source_manifest": {
      "type": "string"
    },
    "default_refresh": {
      "type": "object"
    },
    "extra_nodes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "group_hypothesis_edges": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
          {
            "type": "string"
          },
          {
            "type": "string"
          }
        ],
        "minItems": 2,
        "maxItems": 2
      }
    },
    "safety_rules": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "fact",
          "target",
          "question",
          "priority"
        ],
        "properties": {
          "reuse_existing": {
            "type": "boolean"
          },
          "fact": {
            "type": "object",
            "required": [
              "id",
              "display",
              "value_type"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "display": {
                "type": "string"
              },
              "value_type": {
                "type": "string"
              },
              "refresh": {
                "type": "object",
                "required": [
                  "class",
                  "last_assessed_at",
                  "next_monitor_at",
                  "next_full_review_at",
                  "policy_id"
                ]
              }
            }
          },
          "target": {
            "type": "object",
            "required": [
              "id",
              "display",
              "intents"
            ]
          },
          "question": {
            "type": "object",
            "required": [
              "id",
              "wording",
              "language",
              "mode"
            ]
          },
          "priority": {
            "type": "array"
          },
          "supports": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
