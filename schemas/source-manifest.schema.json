{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Manifest",
  "type": "object",
  "required": [
    "id",
    "version",
    "acquired_at",
    "artifacts",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "acquired_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "version",
          "digest",
          "license_status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "digest": {
            "type": "string"
          },
          "license_status": {
            "enum": [
              "unknown",
              "allowed",
              "restricted",
              "prohibited"
            ]
          }
        }
      }
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
