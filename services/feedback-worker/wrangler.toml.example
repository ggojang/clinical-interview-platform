name = "clinical-interview-feedback"
main = "src/index.js"
compatibility_date = "2026-07-16"

[[d1_databases]]
binding = "DB"
database_name = "clinical-interview-feedback"
database_id = "replace-with-d1-database-id"
migrations_dir = "migrations"

[vars]
RETENTION_DAYS = "90"
TEST_GPT_URL = "https://chatgpt.com/g/g-6a559ef4c77c8191a8d18a03ab76af33-clinical-interview-research-test"

[triggers]
crons = ["17 3 * * *"]
