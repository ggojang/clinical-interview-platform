{
  "id": "knowledge.hira-adequacy-assessment-interviews-2026",
  "version": "0.1.0",
  "status": "research_only",
  "review_status": "unreviewed",
  "usage_modes": ["research_test", "simulation"],
  "purpose": "Conditionally activate patient- or proxy-report collection used by Korean HIRA adequacy assessments without converting observation, test, claim, or medical-record fields into patient questions.",
  "entry_policy": {
    "entry_point": "reason_for_encounter",
    "generic_aliases_ko": ["적정성 평가", "적정성평가", "정형 설문", "정형설문", "공식 설문", "평가 설문"],
    "generic_prompt_ko": "작성하려는 적정성 평가 또는 정형 설문을 선택해 주세요.",
    "specific_alias_match_required": true,
    "never_activate_from_diagnosis_or_symptom_name_alone": true,
    "workflow_states": [
      "entry_unresolved",
      "program_selected",
      "awaiting_start_confirmation",
      "collecting_assessment_context",
      "ready_to_start",
      "in_progress",
      "completed",
      "stopped"
    ],
    "start_confirmation_options": {"1": "예", "2": "아니오", "3": "잘 모르겠음", "4": "답변하지 않음"},
    "after_affirmative": [
      "collect_only_missing_assessment_context_fields",
      "verify_instrument_resource_when_fixed",
      "start_first_source_item_without_reconfirmation"
    ],
    "after_negative": "return_to_open_reason_for_encounter",
    "unknown_title": "preserve_requested_title_and_ask_for_source_or_exact_questionnaire_name",
    "safety_precedence": "time_critical_safety_action_precedes_entry_confirmation"
  },
  "fixed_questionnaire_registration_policy": {
    "purpose": "Allow additional source-controlled fixed questionnaires to use the same Reason-for-Encounter entry workflow without embedding routing logic in the chatbot prompt.",
    "required_metadata": [
      "questionnaire_id",
      "canonical_title",
      "version",
      "source_ref",
      "aliases_ko",
      "start_prompt_ko",
      "resource_ref",
      "runtime_readiness"
    ],
    "registration_rules": {
      "aliases_must_be_specific_to_instrument": true,
      "generic_title_never_autoselects": true,
      "source_resource_required_before_first_item": true,
      "one_start_confirmation_only": true,
      "preserve_source_items_options_order_scoring_and_recall": true,
      "missing_source_must_not_be_reconstructed_by_ai": true
    }
  },
