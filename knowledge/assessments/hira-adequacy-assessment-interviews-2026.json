            {"id": "hira.ltc.fall_days_31_to_180", "text_ko": "31일 전부터 180일 전 사이에 넘어진 적이 있나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report", "medical_record"], "required": true},
            {"id": "hira.ltc.swallowing_difficulty", "text_ko": "음식이나 물을 삼키기 어렵거나 자주 사레가 드나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report", "clinician_observation"], "required": true},
            {"id": "hira.ltc.recent_weight_loss_report", "text_ko": "최근 체중이 줄었다고 느끼거나 들은 적이 있나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": false, "does_not_replace_measurement": true},
            {"id": "hira.ltc.pressure_ulcer_previous_year", "text_ko": "지난 1년 동안 욕창이 생긴 적이 있나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report", "medical_record"], "required": true}
