          "display_ko": "일반정보와 건강습관",
          "items": [
            {"id": "hira.ltc.previous_residence", "text_ko": "입원하시기 전에는 어디에서 생활하셨나요?", "value_type": "coded_or_text", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.education_level", "text_ko": "최종 학력은 어떻게 되나요?", "value_type": "coded", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.current_smoking", "text_ko": "현재 담배를 피우시나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.frequent_alcohol_use", "text_ko": "현재 자주 술을 드시나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.exercise_four_days_thirty_minutes", "text_ko": "보통 일주일에 4일 이상, 한 번에 30분 이상 운동하시나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.three_meals_daily", "text_ko": "보통 하루 세 끼를 드시나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true}
          ]
        },
        {
          "id": "hira.ltc.long_term_care_and_social_needs",
          "display_ko": "장기요양과 사회적 필요",
          "items": [
            {"id": "hira.ltc.long_term_care_grade", "text_ko": "노인장기요양보험 등급을 받았거나 신청 중인가요?", "value_type": "coded_or_text", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.long_term_care_services", "text_ko": "현재 이용 중인 장기요양서비스가 있나요?", "value_type": "multi_text", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.long_term_care_service_intent", "text_ko": "퇴원 후 장기요양서비스를 이용할 의향이 있나요?", "value_type": "coded", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.no_caregiver_or_meal_help", "text_ko": "식사 준비나 돌봄을 도와줄 사람이 없어 어려움이 있나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.utility_shutoff_risk", "text_ko": "공과금을 내지 못해 전기·수도·가스가 끊길 위험이 있나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.housing_instability", "text_ko": "현재 거주할 곳이 불안정하거나 노숙 상태인가요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.financial_difficulty", "text_ko": "의료비·주거비·난방비를 지불하기 어려운가요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.transportation_barrier", "text_ko": "교통 문제 때문에 진료를 받거나 일상생활을 하는 데 어려움이 있나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true},
            {"id": "hira.ltc.food_or_abuse_urgent_need", "text_ko": "식량 부족이나 학대 등 지금 바로 도움이 필요한 문제가 있나요?", "value_type": "boolean", "source": ["patient_report", "proxy_report"], "required": true, "safety_relevant": true}
          ]
        },
        {
          "id": "hira.ltc.history_and_symptoms",
          "display_ko": "낙상·삼킴·피부 병력",
