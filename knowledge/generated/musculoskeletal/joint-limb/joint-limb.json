  "safety_rules": [
    {
      "id": "rule.joint-limb.safety.deformity",
      "priority": 1000,
      "when": {
        "fact": "symptom.joint_limb.visible_deformity",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.open-wound",
      "priority": 1000,
      "when": {
        "fact": "symptom.joint_limb.open_wound_or_exposed_bone",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.cannot-use",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "event.joint_limb.recent_injury",
            "equals": true
          },
          {
            "fact": "symptom.joint_limb.unable_weight_bear_or_use",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.postinjury-numbness",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "event.joint_limb.recent_injury",
            "equals": true
          },
          {
            "fact": "symptom.joint_limb.postinjury_numbness",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.vascular",
      "priority": 1000,
      "when": {
        "fact": "symptom.joint_limb.cold_pale_blue_distal",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.compartment",
      "priority": 1000,
      "when": {
        "fact": "symptom.joint_limb.severe_escalating_pain_tight_swelling",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.spinal-neurology",
      "priority": 1000,
      "when": {
        "fact": "symptom.neck_pain_with_bilateral_weakness_or_clumsiness",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.spinal-bladder",
      "priority": 1000,
      "when": {
        "fact": "symptom.new_bladder_bowel_dysfunction_with_neck_back_pain",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.cardiopulmonary",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.chest_pain",
            "equals": true
          },
          {
            "fact": "symptom.severe_dyspnea",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.hot-joint-fever",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.hot_swollen_joint",
            "equals": true
          },
          {
            "fact": "symptom.fever",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.hot-joint-unwell",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.hot_swollen_joint",
            "equals": true
          },
          {
            "fact": "symptom.systemically_unwell",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.joint-limb.safety.sudden-monoarthritis",
      "priority": 850,
      "when": {
        "fact": "symptom.sudden_severe_single_joint",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    }
  ],
