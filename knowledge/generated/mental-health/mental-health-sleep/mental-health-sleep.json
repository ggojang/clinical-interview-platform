  "safety_rules": [
    {
      "id": "rule.mental-health-sleep.safety.suicide-plan",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "risk.suicidal_thoughts_current",
            "equals": true
          },
          {
            "fact": "risk.suicide_plan_or_intent",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.suicide-means",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "risk.suicidal_thoughts_current",
            "equals": true
          },
          {
            "fact": "risk.access_to_lethal_means",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.unable-safe",
      "priority": 1000,
      "when": {
        "fact": "risk.unable_to_stay_safe",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.recent-attempt",
      "priority": 1000,
      "when": {
        "fact": "event.recent_self_harm_or_suicide_attempt",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.harm-others",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "risk.harm_to_others_thoughts",
            "equals": true
          },
          {
            "fact": "risk.harm_to_others_plan_or_means",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.command-hallucination",
      "priority": 1000,
      "when": {
        "fact": "symptom.command_hallucination_to_harm",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.severe-agitation",
      "priority": 1000,
      "when": {
        "fact": "symptom.severe_agitation_confusion_or_disorganization",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.current-violence",
      "priority": 1000,
      "when": {
        "fact": "risk.safeguarding_or_domestic_violence_current",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.first-psychosis",
      "priority": 900,
      "when": {
        "fact": "symptom.first_onset_hallucination_or_delusion",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.mental-health-sleep.safety.mania-risk",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.markedly_reduced_sleep_with_high_energy",
            "equals": true
          },
          {
            "fact": "symptom.manic_risky_or_disinhibited_behavior",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
