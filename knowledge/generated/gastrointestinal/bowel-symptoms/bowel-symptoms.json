  "safety_rules": [
    {
      "id": "rule.bowel-symptoms.safety.nonstop-bleeding",
      "priority": 1000,
      "when": {
        "fact": "symptom.rectal_bleeding_nonstop",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.large-bleeding",
      "priority": 1000,
      "when": {
        "fact": "symptom.rectal_bleeding_large_volume_or_clots",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.bleeding-collapse",
      "priority": 1000,
      "when": {
        "fact": "symptom.collapse_or_severe_faintness",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.acute-abdomen",
      "priority": 1000,
      "when": {
        "fact": "symptom.sudden_severe_abdominal_pain",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.obstruction",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.unable_to_pass_stool_or_flatus",
            "equals": true
          },
          {
            "fact": "symptom.abdominal_distension",
            "equals": true
          },
          {
            "fact": "symptom.repeated_vomiting",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.black-tarry-stool",
      "priority": 900,
      "when": {
        "fact": "symptom.black_tarry_stool",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.bloody-diarrhea",
      "priority": 900,
      "when": {
        "fact": "symptom.bloody_diarrhea",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.systemic-inflammation",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.fever",
            "equals": true
          },
          {
            "fact": "symptom.systemically_unwell",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.bowel-symptoms.safety.persistent-bleeding-weight-loss",
      "priority": 850,
      "when": {
        "all": [
          {
            "fact": "symptom.rectal_bleeding.recurrent_or_persistent",
            "equals": true
          },
          {
            "fact": "symptom.unintentional_weight_loss",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    }
  ],
