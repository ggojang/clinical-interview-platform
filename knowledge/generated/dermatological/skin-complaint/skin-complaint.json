  "safety_rules": [
    {
      "id": "rule.skin.safety.airway-swelling",
      "priority": 1000,
      "when": {
        "fact": "symptom.throat_or_tongue_swelling",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.breathing",
      "priority": 1000,
      "when": {
        "fact": "symptom.severe_breathing_difficulty",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.collapse",
      "priority": 1000,
      "when": {
        "fact": "symptom.collapse_or_unresponsiveness",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.non-blanching-rapid",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.non_blanching_rash",
            "equals": true
          },
          {
            "fact": "symptom.skin_complaint.rapid_spread",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.non-blanching-systemic",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.non_blanching_rash",
            "equals": true
          },
          {
            "fact": "symptom.fever",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.blistering-mucosal",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.skin_blistering_or_peeling",
            "equals": true
          },
          {
            "fact": "symptom.mucosal_sores",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.confusion-systemic",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.confusion",
            "equals": true
          },
          {
            "fact": "symptom.systemically_unwell",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.cellulitis-systemic",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.skin_hot_painful_swollen",
            "equals": true
          },
          {
            "fact": "symptom.fever",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.rapid-severe-pain",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.skin_complaint.rapid_spread",
            "equals": true
          },
          {
            "fact": "symptom.skin_pain_out_of_proportion",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.skin.safety.fever-immunocompromised",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.fever",
            "equals": true
          },
          {
            "fact": "patient.immunocompromised",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    }
  ],
