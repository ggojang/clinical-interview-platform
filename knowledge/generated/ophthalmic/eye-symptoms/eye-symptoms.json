  "safety_rules": [
    {
      "id": "rule.eye-symptoms.safety.sudden-vision-loss",
      "priority": 1000,
      "when": {
        "fact": "eye.sudden_complete_or_major_vision_loss",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.eye-symptoms.safety.chemical-exposure",
