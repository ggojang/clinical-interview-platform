  "safety_rules": [
    {
      "id": "rule.medication-review.safety.possible-poisoning",
      "priority": 1000,
      "when": {
        "fact": "medication.possible_poisoning_or_extra_dose",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.intentional-overdose",
      "priority": 1000,
      "when": {
        "fact": "mental_health.intentional_overdose_or_self_harm",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.airway-swelling",
      "priority": 1000,
      "when": {
        "fact": "symptom.throat_or_tongue_swelling",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.breathing",
      "priority": 1000,
      "when": {
        "fact": "symptom.severe_breathing_difficulty",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.unresponsive-slow-breathing",
      "priority": 1000,
      "when": {
        "fact": "symptom.unresponsive_or_slow_breathing",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.anticoagulant-bleeding",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.severe_active_bleeding",
            "equals": true
          },
          {
            "fact": "medication.anticoagulant_current",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.severe-hypoglycaemia",
      "priority": 1000,
      "when": {
        "fact": "symptom.severe_hypoglycaemia",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.blistering-mucosal-rash",
      "priority": 1000,
      "when": {
        "fact": "symptom.drug_related_blistering_mucosal_rash",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.medication-review.safety.severe-withdrawal",
      "priority": 900,
      "when": {
        "fact": "medication.abrupt_stop_with_withdrawal",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    }
  ],
