  "safety_rules": [
    {
      "id": "rule.upper-respiratory.safety.breathing-stridor",
      "priority": 1000,
      "when": {
        "fact": "symptom.severe_breathing_or_stridor",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.unable-swallow-drooling",
      "priority": 1000,
      "when": {
        "fact": "symptom.unable_to_swallow_saliva_or_drooling",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.rapid-worsening",
      "priority": 1000,
      "when": {
        "fact": "symptom.upper_respiratory.severe_rapid_worsening",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.allergic-swelling",
      "priority": 1000,
      "when": {
        "fact": "symptom.sudden_lip_tongue_or_throat_swelling",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.orbital-complication",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.periorbital_swelling_or_displaced_eye",
            "equals": true
          },
          {
            "fact": "symptom.double_vision_painful_eye_movement_or_reduced_vision",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.intracranial-warning",
      "priority": 1000,
      "when": {
        "fact": "symptom.sinus_intracranial_warning",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.confusion-systemic",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.confusion",
            "equals": true
          },
          {
            "fact": "symptom.fever",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.immunocompromised-fever",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "patient.immunocompromised",
            "equals": true
          },
          {
            "fact": "symptom.fever",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.dehydration",
      "priority": 900,
      "when": {
        "fact": "symptom.dehydration_or_unable_fluids",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.upper-respiratory.safety.deep-neck-warning",
      "priority": 900,
      "when": {
        "fact": "symptom.neck_swelling_trismus_or_muffled_voice",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    }
  ],
