          },
          {
            "fact": "symptom.presyncope",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.palpitations.safety.palpitations-syncope",
      "priority": 1000,
      "when": {
        "fact": "symptom.syncope",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.palpitations.safety.current-not-settling",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.palpitations.current",
            "equals": true
          },
          {
