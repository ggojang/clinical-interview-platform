        "fact": "symptom.syncope_during_exertion",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.palpitations.safety.heart-disease-worsening",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "history.known_heart_disease",
