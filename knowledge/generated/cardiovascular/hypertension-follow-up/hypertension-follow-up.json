  "safety_rules": [
    {
      "id": "rule.hypertension-follow-up.safety.severe-bp-confusion",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "blood_pressure.repeated_180_120_or_higher",
            "equals": true
          },
          {
            "fact": "symptom.new_confusion",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.hypertension-follow-up.safety.severe-bp-chest-pain",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "blood_pressure.repeated_180_120_or_higher",
            "equals": true
          },
          {
            "fact": "symptom.chest_pain",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.hypertension-follow-up.safety.severe-bp-dyspnea",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "blood_pressure.repeated_180_120_or_higher",
            "equals": true
          },
          {
            "fact": "symptom.severe_dyspnea",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.hypertension-follow-up.safety.severe-bp-focal-deficit",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "blood_pressure.repeated_180_120_or_higher",
            "equals": true
          },
          {
            "fact": "symptom.new_focal_neurological_deficit",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.hypertension-follow-up.safety.severe-bp-low-urine",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "blood_pressure.repeated_180_120_or_higher",
            "equals": true
          },
          {
            "fact": "symptom.markedly_reduced_urine",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.hypertension-follow-up.safety.pregnancy-severe-bp",
      "priority": 950,
      "when": {
        "all": [
          {
            "fact": "patient.pregnant_or_postpartum",
            "in": [
              "pregnant",
              "postpartum_6_weeks"
            ]
          },
          {
            "fact": "blood_pressure.pregnancy_160_110_or_higher",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.hypertension-follow-up.safety.pregnancy-warning",
      "priority": 950,
      "when": {
        "all": [
          {
            "fact": "patient.pregnant_or_postpartum",
            "in": [
              "pregnant",
              "postpartum_6_weeks"
            ]
          },
          {
            "fact": "symptom.preeclampsia_warning_features",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.hypertension-follow-up.safety.current-syncope",
