  "safety_rules":[
    {"id":"rule.chest-pain.safety.current-long-duration","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.current","equals":true},{"fact":"symptom.chest_pain.longer_than_15_minutes","equals":true}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.current-pressure","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.current","equals":true},{"fact":"symptom.chest_pain.quality","in":["pressure","tightness","heaviness"]}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.current-radiation","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.current","equals":true},{"fact":"symptom.chest_pain.radiation","equals":true}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.current-breathlessness","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.current","equals":true},{"fact":"symptom.dyspnea","in":["moderate","severe"]}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.current-systemic-features","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.current","equals":true},{"fact":"symptom.marked_sweating","equals":true},{"fact":"symptom.nausea_or_vomiting","equals":true}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.syncope","priority":1000,"when":{"fact":"symptom.syncope","equals":true},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.sudden-severe","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.onset","equals":"sudden"},{"fact":"symptom.chest_pain.severity","equals":"severe"}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.neurological-deficit","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.current","equals":true},{"fact":"symptom.neurological_deficit","equals":true}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.pleuritic-dyspnea","priority":1000,"when":{"all":[{"fact":"symptom.chest_pain.pleuritic","equals":true},{"fact":"symptom.dyspnea","in":["moderate","severe"]}]},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.hemoptysis","priority":1000,"when":{"fact":"symptom.hemoptysis","equals":true},"then":{"safety_level":"emergency","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.resolved-recent-coronary-features","priority":900,"when":{"all":[{"fact":"symptom.chest_pain.current","equals":false},{"fact":"symptom.chest_pain.within_last_72_hours","equals":true},{"fact":"symptom.chest_pain.exertional","equals":true}]},"then":{"safety_level":"urgent","action":"human_handoff","suppress_routine":true}},
    {"id":"rule.chest-pain.safety.vte-context","priority":900,"when":{"all":[{"fact":"symptom.chest_pain.pleuritic","equals":true},{"fact":"symptom.unilateral_leg_pain_swelling","equals":true}]},"then":{"safety_level":"urgent","action":"human_handoff","suppress_routine":true}}
