            "equals": true
          },
          {
            "fact": "symptom.faint_confused_clammy",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.edema.safety.allergic-swelling",
      "priority": 1000,
      "when": {
        "fact": "symptom.sudden_face_tongue_throat_swelling",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.edema.safety.pregnancy-warning",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "patient.pregnant_or_postpartum",
            "in": [
              "pregnant",
              "postpartum_6_weeks"
            ]
          },
          {
            "fact": "symptom.preeclampsia_warning_features",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.edema.safety.unilateral-pain",
      "priority": 900,
      "when": {
        "fact": "symptom.unilateral_leg_pain_swelling",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.edema.safety.red-hot-fever",
      "priority": 900,
      "when": {
        "all": [
          {
