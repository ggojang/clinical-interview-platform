  "safety_rules": [
    {
      "id": "rule.edema.safety.severe-dyspnea",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.edema.current",
            "equals": true
          },
          {
            "fact": "symptom.severe_dyspnea",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.edema.safety.chest-pain",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.edema.current",
            "equals": true
          },
