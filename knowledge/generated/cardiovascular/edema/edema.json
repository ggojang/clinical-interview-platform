          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.edema.safety.rapid-low-urine",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.edema.rapid_generalized_worsening",
