  "safety_rules": [
    {
      "id": "rule.headache.safety.sudden-peak",
      "priority": 1000,
      "when": {
        "fact": "symptom.headache.maximum_within_5_minutes",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.neurological-deficit",
      "priority": 1000,
      "when": {
        "fact": "symptom.neurological_deficit",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.altered-consciousness",
      "priority": 1000,
      "when": {
        "fact": "symptom.altered_consciousness_or_cognition",
        "equals": true
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.meningitis-combination",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.fever",
            "equals": true
          },
          {
            "fact": "symptom.neck_stiffness",
            "equals": true
          },
          {
            "fact": "symptom.altered_consciousness_or_cognition",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.recent-head-trauma",
      "priority": 900,
      "when": {
        "fact": "history.recent_head_trauma",
        "equals": true
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.painful-red-eye-vision",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.painful_red_eye",
            "equals": true
          },
          {
            "fact": "symptom.visual_disturbance",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.worsening-fever",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.headache.worsening",
            "equals": true
          },
          {
            "fact": "symptom.fever",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.new-immunocompromised",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.headache.new_onset",
            "equals": true
          },
          {
            "fact": "patient.immunocompromised",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.new-malignancy-history",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.headache.new_onset",
            "equals": true
          },
          {
            "fact": "history.malignancy",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.headache.safety.new-unexplained-vomiting",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.headache.new_onset",
            "equals": true
          },
          {
            "fact": "symptom.unexplained_vomiting",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    }
