  "safety_rules": [
    {
      "id": "rule.dizziness-syncope.safety.sudden-neurological-deficit",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.dizziness.sudden_onset",
            "equals": true
          },
          {
            "fact": "symptom.neurological_deficit",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.sudden-new-unsteadiness",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.dizziness.sudden_onset",
            "equals": true
          },
          {
            "fact": "symptom.new_gait_unsteadiness",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.sudden-new-deafness",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.dizziness.sudden_onset",
            "equals": true
          },
          {
            "fact": "symptom.new_hearing_loss",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.acute-vestibular-syndrome",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.dizziness.sudden_onset",
            "equals": true
          },
          {
            "fact": "symptom.new_gait_unsteadiness",
            "equals": true
          },
          {
            "fact": "symptom.nausea_or_vomiting",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.incomplete-recovery",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.syncope.occurred",
            "equals": true
          },
          {
            "fact": "symptom.syncope.full_recovery",
            "equals": false
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.syncope-chest-pain",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.syncope.occurred",
            "equals": true
          },
          {
            "fact": "symptom.chest_pain",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.syncope-injury",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.syncope.occurred",
            "equals": true
          },
          {
            "fact": "event.syncope.injury",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.syncope-exertion",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.syncope.occurred",
            "equals": true
          },
          {
            "fact": "event.syncope.during_exertion",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "urgent",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
      "id": "rule.dizziness-syncope.safety.syncope-breathlessness",
      "priority": 900,
      "when": {
        "all": [
          {
            "fact": "symptom.syncope.occurred",
