  "safety_rules": [
    {
      "id": "rule.focal-neurology.safety.sudden-unilateral",
      "priority": 1000,
      "when": {
        "all": [
          {
            "fact": "symptom.focal_neurology.sudden_onset",
            "equals": true
          },
          {
            "fact": "symptom.focal_neurology.one_sided",
            "equals": true
          }
        ]
      },
      "then": {
        "safety_level": "emergency",
        "action": "human_handoff",
        "suppress_routine": true
      }
    },
    {
