  "status": "synthetic",
  "contains_real_patient_data": false,
  "coverage_scope": "all_implemented_symptom_packages",
  "cases": [
    {
      "id": "HANDOFF-INCOMPLETE-FIRST-ENCOUNTER",
      "condition": "required symptom Facts remain not asked",
      "expected": ["missing_required_fact_ids", "safety_relevant_fact_markers"]
    },
    {
      "id": "HANDOFF-COMPLETE-WITH-DATA-ABSENT",
      "condition": "required Facts are known or carry dataAbsentReason",
      "expected": ["package_clinical_entries", "data_absent_fact_ids", "no_silent_negative"]
    },
    {
      "id": "HANDOFF-PROXY-REMOTE-FOLLOW-UP",
      "condition": "caregiver answers during remote follow-up",
      "expected": ["proxy_report", "remote_assessment_limitations", "encounter_context"]
    },
    {
      "id": "HANDOFF-SAFETY-ESCALATION",
      "condition": "urgent or emergency Rule is triggered before routine completion",
      "expected": ["safety_status", "triggered_rules", "missing_required_fact_ids"]
    },
    {
      "id": "HANDOFF-CONFLICTING-ANSWER",
      "condition": "two incompatible answers are preserved",
      "expected": ["conflicting_fact_ids", "no_silent_overwrite"]
    },
    {
      "id": "HANDOFF-MEDICATION-STATUS-REQUIRED-VALUESET",
      "condition": "a first-encounter medication entry is reviewed for clinician submission",
      "expected": [
        "one_atomic_status_question_per_medication_entry",
        "official_MedicationStatement_status_choices",
        "required_binding_disallows_outside_code",
        "QuestionnaireResponse_valueCoding_ready",
        "unknown_preserved_as_official_status_code",
        "no_local_code_fallback_for_required_binding"
      ]
    }
  ],
  "required_entry_fields": [
    "fact_id",
    "question_label",
    "clinical_group_ids",
    "status",
    "value",
    "dataAbsentReason",
    "confidence",
