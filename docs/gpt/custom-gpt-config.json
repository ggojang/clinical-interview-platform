{
  "id": "clinical-interview-research-test.custom-gpt-config",
  "version": "1.42.0",
  "status": "research_only",
  "conversation_starters": [
    "평가/설문 목록",
    "오늘 불편한 증상이나 상담받고 싶은 내용을 입력하겠습니다",
    "건강검진 문진을 시작하고 싶습니다",
    "환자경험평가"
  ],
  "conversation_starter_policy": {
    "primary": "평가/설문 목록",
    "primary_is_required": true,
    "selection_sends_exact_text": true,
    "selection_opens_catalog_without_activation": true,
    "keep_when_republishing": true
  },
  "editor_application": {
    "surface": "ChatGPT Custom GPT editor",
    "field": "Conversation starters",
    "requires_editor_save_or_update": true,
    "repository_changes_do_not_modify_the_editor_field_automatically": true
  },
  "anonymous_test_feedback": {
    "action": "optional_separate_action",
    "operation": "submitAnonymousTestFeedback",
    "consent_version": "feedback-consent.v1",
    "offer_only_after_explicit_end": true,
    "send_only_after_separate_affirmative_answer": true,
    "completion_confirmation_is_not_feedback_consent": true,
    "contains_raw_answers": false,
    "contains_free_text": false,
    "contains_demographics_or_identifiers": false,
    "decline_has_no_effect": true,
    "requires_editor_action_install_and_save": true
  },
  "anonymous_test_session_analytics": {
    "action": "content_free_start_event",
    "operation": "recordAnonymousTestSessionStart",
    "trigger": "once_after_first_user_message",
    "is_consequential": false,
    "notice_required_before_call": true,
    "literal_page_open_observable": false,
    "contains_user_message": false,
    "contains_reason_for_encounter": false,
    "contains_demographics_or_identifiers": false,
    "contains_network_identity": false,
    "retention_days": 90,
    "reuse_session_id_for_consented_end_feedback": true,
    "requires_editor_action_install_and_save": true
  },
  "anonymous_test_entry_analytics": {
    "url": "https://clinical-interview-feedback.seungjong-yu.workers.dev/test",
    "event_type": "tracked_entry_opened",
    "counts_page_opens_not_unique_people": true,
    "direct_gpt_page_open_observable": false,
    "contains_user_input_or_answers": false,
    "contains_network_identity_or_cookie": false,
    "retention_days": 90
  },
  "contains_patient_responses": false
}
