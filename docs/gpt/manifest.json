      "may_offer_one_concise_normalized_interpretation": true
    },
    "preserve_current_question_as_unanswered": true,
    "provenance_marker": "출처: [공동 작업 지식] 응답 재확인 정책 · [AI 표현] 재질문",
    "retry_policy": {
      "after_repeated_failure_offer_unknown_decline_or_free_text": true,
      "clarification_does_not_count_as_a_new_unique_clinical_question": true,
      "never_force_data_absent_reason_without_explicit_user_choice": true
    },
    "safety": {
      "preserve_unanswered_question_when_safety_interrupts": true,
      "urgent_or_emergency_routing_precedes_clarification": true
    },
    "trigger_conditions": [
      "possible_typographical_error",
      "invalid_or_out_of_range_option_number",
      "ambiguous_meaning",
      "answer_cannot_be_reliably_mapped_to_current_fact"
    ]
  },
