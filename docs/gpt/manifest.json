  "question_choice_semantic_alignment_policy": {
    "binary_single_proposition": {
      "display_group_label_ko": "응답",
      "domain_options": [
        {
          "code": "yes",
          "display_ko": "예",
          "number": 1
        },
        {
          "code": "no",
          "display_ko": "아니오",
          "number": 2
        }
      ],
      "example_stem_ko": "지금 갑자기 시작된 참기 어려울 정도의 심한 복통이 있나요?",
      "forbidden_stem_phrases": [
        "다음 중",
        "해당되는 항목",
        "모두 골라"
      ],
      "metadata_options": [
        {
          "code": "unknown",
          "display_ko": "잘 모르겠음",
          "number": 3
        },
        {
          "code": "decline",
          "display_ko": "답변하지 않음",
          "number": 5
        }
      ],
      "options_answer_the_whole_proposition": true,
      "stem_rule": "ask_one_complete_yes_or_no_proposition",
      "use_when": "one_clinical_proposition_is_being_asked"
    },
    "exactly_one_presentation_pattern": true,
    "invalid_combinations": [
      "plural_or_select_from_stem_with_only_one_clinical_domain_option",
      "checklist_stem_with_yes_or_no_options",
      "binary_stem_with_multiple_unlabeled_clinical_findings",
      "warning_paragraph_that_introduces_additional_unoffered_answer_candidates"
    ],
    "multiple_clinical_choices": {
      "append_order": [
        "none_of_the_above",
        "unknown",
        "decline"
      ],
      "display_group_labels_ko": {
        "domain_options": "해당 증상 — 복수 선택 가능",
        "response_state_options": "그 외 응답"
      },
      "do_not_put_unoffered_clinical_findings_in_trailing_warning_text": true,
      "do_not_use_yes_or_no_as_domain_options": true,
      "every_clinical_finding_must_be_a_displayed_domain_option": true,
      "exclusive_options": [
        "none_of_the_above",
        "unknown",
        "decline"
      ],
      "numbering": "continuous_after_all_clinical_domain_options",
      "numeric_reply_accepts": "one_or_more_option_numbers",
      "stem_must_state": [
        "multiple_choice",
        "select_all_that_apply"
      ],
      "use_when": "two_or_more_distinct_clinical_findings_are_being_offered"
    },
    "on_validation_failure": "rewrite_stem_and_complete_option_set_before_sending",
    "pre_send_validation_required": true,
    "provenance_marker": "출처: [공동 작업 지식] 질문-보기 정합성 정책 · [AI 표현] 문장",
    "safety_gate": {
      "map_each_selected_finding_to_its_own_fact_or_rule": true,
      "none_unknown_and_decline_never_mean_a_clinical_finding": true,
      "prefer_single_binary_question_when_only_one_rule_is_activated": true,
      "same_alignment_rules_apply": true,
      "use_checklist_only_for_findings_supported_by_loaded_compiled_rules": true
    }
  },
