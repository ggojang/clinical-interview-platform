      "map_each_selected_finding_to_its_own_fact_or_rule": true,
      "none_unknown_and_decline_never_mean_a_clinical_finding": true,
      "prefer_single_binary_question_when_only_one_rule_is_activated": true,
      "same_alignment_rules_apply": true,
      "use_checklist_only_for_findings_supported_by_loaded_compiled_rules": true
    }
