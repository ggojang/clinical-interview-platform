  "response_provenance_display_policy": {
    "compact_marker_required_for_every_question": true,
    "final_report_section_ko": "출처 및 생성 구분",
    "future_fhir_provenance_ready": true,
    "never_hide_mixed_origin": true,
    "never_label_ai_generated_content_as_project_knowledge": true,
    "question_marker_examples": {
      "ai_only_clarification": "출처: [AI 자체 생성] 프로젝트 지식에 없는 보완 질문",
      "compiled_question_reworded": "출처: [공동 작업 지식] 질문 목적·선택 · [AI 표현] 문장",
      "document_follow_up": "근거 정보: [첨부자료] · 질문 생성: [AI 자체 생성]",
      "terminology_result": "용어: [STOM 용어 조회] 후보·코드 검증"
    },
    "record_fields": [
      "origin_class",
      "project_object_ids",
      "external_source_ids",
      "terminology_source_and_version",
      "ai_contribution",
      "uncertainty"
    ],
    "require_project_object_or_source_id_for_project_label": true,
    "show_legend_once_per_conversation": true,
    "source_classes": {
      "ai_expression": {
        "display_ko": "AI 표현",
        "meaning": "language adaptation or concise rewording without changing project semantics"
      },
      "ai_generated": {
        "display_ko": "AI 자체 생성",
        "meaning": "clarification, interpretation, explanation, or candidate not present in compiled project knowledge"
      },
      "project_knowledge": {
        "display_ko": "공동 작업 지식",
        "meaning": "compiled Knowledge, Fact, Question, Rule, policy, or source summary from this repository"
      },
      "stom_terminology": {
        "display_ko": "STOM 용어 조회",
        "meaning": "live provisional terminology candidate or code verification"
      },
      "uploaded_document": {
        "display_ko": "첨부자료",
        "meaning": "information explicitly extracted from an uploaded file or scan"
      },
      "user_report": {
        "display_ko": "사용자 제공",
        "meaning": "information directly reported by the user"
      }
    },
    "timing": "after_reason_for_encounter_before_first_question"
  },
  "result_follow_up_policy": {
    "clarification_question_ko": "오늘은 의료기관에서 검사결과를 확인하려는 것인가요, 아니면 검사결과의 판독이나 설명을 원하시나요?",
    "institution_result_check": {
      "check": [
        "result.abnormal_notice",
        "result.new_concern"
      ],
      "request_upload": false,
      "when_no_abnormality_or_concern": "ask_additional_request_then_complete"
    },
    "interpretation_request": {
      "accepted_input": [
        "image",
        "pdf",
        "text"
      ],
      "never_repeat_upload_request": true,
      "request_upload_once": true
    },
    "options": [
      {
        "code": "institution_result_check",
        "display_ko": "의료기관에서 결과 확인"
      },
      {
        "code": "interpretation_request",
        "display_ko": "검사결과 판독·설명 요청"
      },
      {
        "code": "both",
        "display_ko": "둘 다"
      }
    ]
  },
  "review_status": "unreviewed",
  "status": "research_only",
  "terminology_lookup_policy": {
    "action_schema_url": "https://ggojang.github.io/clinical-interview-platform/gpt/stom-openapi.yaml",
    "clinical_rule_selection_from_live_terminology": false,
    "fallback": "preserve_free_text_and_continue_with_compiled_knowledge",
    "mapping_flow": [
      "normalize_korean_or_english_free_text_locally",
      "search_up_to_five_active_candidates",
      "select_or_ask_when_ambiguous",
      "verify_selected_code_with_fhir_lookup",
      "preserve_server_version_and_mapping_provenance"
    ],
    "review_status": "unreviewed",
    "runtime_use": "optional_semantic_alignment_only",
    "send_direct_identifiers": false,
