{
  "additional_comment_policy": {
    "current_question_remains_unanswered": true,
    "do_not_force_map_to_current_question": true,
    "fact_id": "interview.additional_comment",
    "never_publish_raw_response": true,
    "reassess_safety": true,
    "report_resolved_and_unresolved_separately": true,
    "resolution_includes_service_improvement": true,
    "resolve_when_safe_and_within_scope": true
  },
  "answer_revision_policy": {
    "after_completion": {
      "classify_as_amendment_not_new_encounter_when_same_reason_for_encounter": true,
      "invalidate_prior_final_summary": true,
      "questionnaire_response_status": "amended",
      "require_completion_reconfirmation_after_recalculation": true
    },
    "audit": {
      "data_absent_reason_may_be_replaced_but_remains_in_history": true,
      "future_fhir_provenance_ready": true,
      "never_delete_or_silently_overwrite_prior_answer": true,
      "preserve_prior_value_response_state_evidence_and_timestamp": true,
      "record_correction_actor_time_reason_and_source": true
    },
    "available_states": [
      "in_progress",
      "awaiting_user_confirmation",
      "completed"
    ],
    "completion_hint_ko": "답변을 바꾸려면 언제든지 '수정'이라고 입력하세요.",
    "conditional_branch_change": {
      "do_not_delete_answers_from_inactive_branch": true,
      "new_branch_facts_become_required_when_applicable": true,
      "prior_branch_answers_are_preserved_in_history": true,
      "prior_branch_answers_do_not_satisfy_new_branch": true
    },
    "edit_reference_format": "E{positive_integer}",
    "entry_commands": [
      "수정",
      "답변 수정",
      "edit answer"
    ],
    "menu_instruction_ko": "수정할 항목의 E번호를 '수정 E2'처럼 입력해 주세요.",
    "menu_item_fields": [
      "edit_reference",
      "question_or_item_label",
      "current_value_or_response_state",
      "fact_id"
    ],
    "never_use_bare_question_option_number_as_edit_reference": true,
    "provenance_marker": "출처: [공동 작업 지식] 답변 수정 정책 · [AI 표현] 안내 문장",
    "safety": {
      "explain_why_escalation_is_recommended": true,
      "new_urgent_or_emergency_result_interrupts_revision_flow": true,
      "reassessment_precedes_routine_resume": true
    },
    "value_entry": {
      "binary_numeric_codes": {
        "1": "yes",
        "2": "no",
        "3": "asked-unknown",
        "5": "asked-declined"
      },
      "do_not_apply_replacement_to_any_other_fact": true,
      "free_text_allowed_when_original_fact_accepts_free_text": true,
      "reuse_original_question_choices_when_available": true
    },
    "workflow": [
      "preserve_current_unanswered_question",
      "show_only_answers_available_for_revision",
      "select_one_item_by_edit_reference",
      "show_current_answer_and_request_replacement",
      "record_replacement_as_explicit_correction",
      "recompute_safety_rules",
      "recompute_conditional_question_branch",
      "recompute_missing_conflicting_and_data_absent_facts",
      "recompute_completion_eligibility",
      "confirm_changed_item_and_resume_or_reopen_questionnaire"
    ]
  },
  "answer_understanding_clarification_policy": {
    "ambiguous_flow": {
      "allow_korean_or_english_free_text_when_fact_supports_free_text": true,
      "ask_one_specific_clarifying_question_at_a_time": true,
      "message_ko": "응답을 명확히 이해하지 못했습니다. 아래 질문에 다시 답해 주세요.",
      "repeat_original_question_with_original_choices_when_no_safe_interpretation": true
    },
    "audit_fields": [
      "question_id",
      "fact_id",
      "raw_response_in_conversation_only",
      "clarification_reason",
      "suggested_interpretation",
      "confirmation_result",
      "attempt_count"
    ],
    "decision_order": [
      "extract_and_apply_any_explicit_safety_relevant_information",
      "reassess_safety",
      "determine_whether_response_answers_current_question",
      "route_clearly_unrelated_content_to_off_path_recovery",
      "request_targeted_clarification_when_current_answer_remains_uncertain"
    ],
    "do_not_advance_to_next_question": true,
    "do_not_infer_negative_unknown_or_refusal_from_parse_failure": true,
    "do_not_store_suggested_interpretation_as_fact_before_confirmation": true,
